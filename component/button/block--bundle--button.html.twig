{#
  =============================================================================
  COMPONENT: Action Button / Global CTA (rebuilt 2026-07-10)
  COMPLIANCE: Section 508 / WCAG 2.2 Level AA

  - Title renders as a PLAIN heading (never wrapped in a link).
  - field_text_alignment justifies the link cluster left/center/right.
  - field_button_layout renders links horizontal (default) or stacked
    vertically ('vertical_layout' class, see css/button.css).
  - Button look (no radius, padding, min-width) comes from the global
    `.card .btn` rules in component/macros/css/card.css — same as every
    other component's buttons.
  =============================================================================
#}
{% import '@cua_theme/component/macros/card_title.html.twig' as titleMacros %}

{{ attach_library('cua_theme/call-to-action') }}
{{ attach_library('cua_theme/button') }}

{% set button_classes = [
    'block',
    'block-' ~ configuration.provider|clean_class,
    'button card',
    color_border ?: null,
    text_color ?: null,
    id ? 'block--' ~ id|replace({"_": "-"})|clean_class : null,
] | merge(utility_classes ?: []) | filter(v => v) | join(' ') %}

{% set unique_id = 'button-' ~ elements.content['#block_content'].id()|default(random(1000)) %}
{% set heading_id = unique_id ~ '-title' %}

{# Options with backward-compatible defaults for blocks saved before the
   fields existed: left-aligned, horizontal. #}
{% set alignment = text_alignment ?: 'd-flex justify-content-start' %}
{% set layout = button_layout ?: 'flex-row gap-2' %}
{% set is_vertical = layout == 'vertical_layout' %}

{# In a column flexbox the cross axis is horizontal, so map the chosen
   justification to align-items for the vertical layout. #}
{% set vertical_align = '' %}
{% if is_vertical %}
  {% set vertical_align = 'center' in alignment ? 'align-items-center'
    : ('end' in alignment ? 'align-items-end' : 'align-items-start') %}
{% endif %}

{# Write attributes explicitly — `attributes` arrives NULL/empty in some
   Layout Builder render paths, and chaining methods on it in a set-tag
   silently yields an empty print (bare <div>). #}
<div id="{{ unique_id }}"
     class="{{ button_classes }}{{ attributes.hasClass is defined ? ' ' ~ attributes.class : '' }}"
     role="region"
     {% if label %}aria-labelledby="{{ heading_id }}"{% else %}aria-label="{{ 'Action links'|t }}"{% endif %}
     {{ attributes ? attributes|without('id', 'class', 'role', 'aria-labelledby', 'aria-label') : '' }}>

  {{- title_prefix -}}
  {{- title_suffix -}}

  {% if label %}
    {# Empty links array = plain heading, never linked. #}
    {{ titleMacros.render_title(
        label,
        '',
        '',
        center_content,
        text_alignment,
        text_color,
        padding,
        false,
        [],
        heading_id
    ) }}
  {% endif %}

  {% if content %}
    {% import '@cua_theme/component/macros/card_body.html.twig' as bodyMacros %}
    {{ bodyMacros.render_body(content, padding, text_color, text_alignment) }}
  {% endif %}

  {% set footer_classes = [
      'card-footer d-flex mt-3 mb-5',
      alignment,
      layout,
      vertical_align,
      container_size,
      position_container,
      padding,
  ] | filter(v => v) | join(' ') %}

  <div class="{{ footer_classes }}"
       {% if links|length > 1 %} role="group" aria-label="{{ label ?: 'Related links'|t }}" {% endif %}>
    {% for link in links %}
      {% set outline_class = outline ? outline ~ 'btn-' ~ button_color : 'btn-' ~ button_color %}
      <a href="{{ link.url }}"
         class="{{ ['card-link btn text-decoration-none', outline_class] | filter(v => v) | join(' ') }}">
        {{ link.title }}
      </a>
    {% endfor %}
  </div>
</div>
