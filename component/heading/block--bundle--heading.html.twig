{#-
  =============================================================================
  COMPONENT: Global Section Heading
  STABILITY: Production-Stable
  COMPLIANCE: Section 508 / WCAG 2.2 Level AA / HTML5 Semantic Tier 1
  SCHEMA: None — heading blocks are presentational structure; headings are
          already semantic HTML readable by AI crawlers directly.
  =============================================================================
#}

{% import '@cua_theme/component/macros/card_title.html.twig' as titleMacros %}
{{ attach_library('cua_theme/heading') }}

{%- set heading_classes = [
  'container',
  'block',
  'block-' ~ configuration.provider|clean_class,
  'block-' ~ plugin_id|clean_class,
  'heading',
  'px-2 pt-4 clearfix',
  text_color ?: null,
  id ? 'block--' ~ id|replace({'_': '-'})|clean_class : null,
]|merge(utility_classes ?: [])|filter(v => v)|join(' ')|trim -%}

{# Unique ID — range 1000-9999 for low collision resistance #}
{%- set unique_id  = 'heading-' ~ elements.content['#block_content'].id()|default(random(1000, 9999)) -%}
{%- set heading_id = unique_id ~ '-title' -%}

<div{{ attributes
  .setAttribute('id', unique_id)
  .addClass(heading_classes)
  .setAttribute('role', 'region')
  .setAttribute('aria-labelledby', heading_id)
}}>

  <div class="row pt-2">

    {{- title_prefix -}}
    {{- title_suffix -}}

    {# Primary Heading — striptags guards against editor-pasted markup #}
    {%- if heading -%}
      <h2 id="{{ heading_id }}"{{ title_attributes.addClass('title') }}>
        {{- heading|striptags|trim -}}
      </h2>
    {%- else -%}
      <h2 id="{{ heading_id }}" class="title">
        {{- label|striptags|trim -}}
      </h2>
    {%- endif -%}

    {# Subtitle — H3 enforces logical heading order per WCAG 1.3.1 #}
    {%- if subtitle -%}
      <h3 class="title px-3 pb-4">
        {{- subtitle|striptags|trim -}}
      </h3>
    {%- endif -%}

  </div>
</div>
