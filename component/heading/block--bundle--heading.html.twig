{#-
  =============================================================================
  COMPONENT: Global Section Heading
  STABILITY: Production-Stable
  COMPLIANCE: Section 508 / WCAG 2.2 Level AA / HTML5 Semantic Tier 1
  SCHEMA: None — heading blocks are presentational structure; headings are
          already semantic HTML readable by AI crawlers directly.
  =============================================================================
#}

{% import '@cua_theme/component/macros/card_title.html.twig' as titleMacros %}
{{ attach_library('cua_theme/heading') }}

{%- set heading_classes = [
  'container',
  'block',
  'block-' ~ configuration.provider|clean_class,
  'block-' ~ plugin_id|clean_class,
  'heading',
  'px-2 pt-4 clearfix',
  text_color ?: null,
  id ? 'block--' ~ id|replace({'_': '-'})|clean_class : null,
]|merge(utility_classes ?: [])|filter(v => v)|join(' ')|trim -%}

{# Unique ID — range 1000-9999 for low collision resistance #}
{%- set unique_id  = 'heading-' ~ elements.content['#block_content'].id()|default(random(1000, 9999)) -%}
{%- set heading_id = unique_id ~ '-title' -%}

{# 1. Pre-clean strings to prevent whitespace or empty HTML tags from passing checks #}
{%- set clean_heading  = heading|striptags|trim -%}
{%- set clean_label    = label|striptags|trim -%}
{%- set clean_subtitle = subtitle|striptags|trim -%}

{%- set has_heading  = clean_heading is not empty or clean_label is not empty -%}
{%- set has_subtitle = clean_subtitle is not empty -%}

{# 2. Initialize base block attributes #}
{%- set attributes = attributes.setAttribute('id', unique_id).addClass(heading_classes) -%}

{# 3. Apply ARIA landmark properties ONLY if a primary heading actually exists to label it #}
{%- if has_heading -%}
	{%- set attributes = attributes.setAttribute('role', 'region').setAttribute('aria-labelledby', heading_id) -%}
{%- endif -%}

<div{{attributes}}>
	<div class="row pt-2">

		{{- title_prefix -}}
		{{- title_suffix -}}

		{# Primary Heading Block #}
		{%- if has_heading -%}
			{%- if clean_heading is not empty -%}
				<h2 id="{{ heading_id }}" {{ title_attributes.addClass('title') }}>
					{{- clean_heading -}}
				</h2>
			{%- else -%}
				<h2 id="{{ heading_id }}" class="title">
					{{- clean_label -}}
				</h2>
			{%- endif -%}
		{%- endif -%}

		{# Subtitle Block #}
		{%- if has_subtitle -%}
			<h3 class="title px-3 pb-4">
				{{- clean_subtitle -}}
			</h3>
		{%- endif -%}

	</div>
</div>