{#-
  =============================================================================
  COMPONENT: Basic Content Block
  COMPLIANCE: WCAG 2.2 AA / Section 508
  SCHEMA STRATEGY (2026-06):
    - JSON-LD replaces all Microdata attributes
    - CreativeWork is the base type — accurate for generic text/content blocks
    - name always emitted: label when present, else truncated description —
      prevents "Unnamed - CreativeWork" entries in validators
    - Link handling:
        * default: single link emitted as plain url on the CreativeWork
        * schema_action_type, if explicitly configured, adds a nested
          potentialAction of that type (e.g. DonateAction, RegisterAction,
          ViewAction)
        * ReadAction is NEVER emitted, even if configured — it is a
          ConsumeAction subtype and Google requires expectsAcceptanceOf
          (Offer) on all ConsumeActions; legacy configs are remapped to url
    - URLs always absolute: relative paths prefixed with site_base
      (base_url unavailable in this block template context)
    - description: space inserted before tags prior to striptags so heading
      and paragraph text don't concatenate without whitespace
    - All itemscope / itemtype / itemprop removed from HTML
  =============================================================================
-#}
{%- import '@cua_theme/component/macros/card_title.html.twig' as titleMacros -%}

{# ID and Class Logic #}
{%- set unique_id = 'block--node-basic-block--' ~ elements.content['#block_content'].id()|replace({'_': '-', ':': '--'}) -%}
{%- set title_id  = unique_id ~ '-title' -%}

{%- set basic_classes = [
  'block',
  'block-' ~ configuration.provider|clean_class,
  'block-' ~ plugin_id|clean_class,
  'basic-block card rounded-0 h-100',
  text_alignment,
  text_color,
  color_background ?: 'bg-transparent',
  color_border ?: 'border-0',
  id ? 'block--' ~ id|replace({'_': '-'})|clean_class : null,
]|merge(utility_classes ?: [])|filter(v => v)|join(' ') -%}

{# Link Detection #}
{%- set links_count = links|length -%}
{%- set single_link = (links_count == 1) ? links|first : null -%}

{# ── JSON-LD Schema ─────────────────────────────────────────────────────── #}
{%- set site_base = 'https://www.giving.cu.edu' -%}
{%- set _block_entity = elements.content['#block_content'] -%}

{# Description: space-pad tags before stripping so heading text and body
   text don't glue together (e.g. "Your Giving Changes LivesOur partnerships") #}
{%- set _description = _block_entity.body.value
  ? _block_entity.body.value|replace({'<': ' <'})|striptags|trim|slice(0, 300)|trim
  : label|striptags|trim -%}

{# Name: label wins; fall back to truncated description so the node is
   never unnamed in validators #}
{%- set _name = label|striptags|trim -%}
{%- if not _name and _description -%}
  {%- set _name = _description|length > 60 ? _description|slice(0, 60)|trim ~ '…' : _description -%}
{%- endif -%}

{# Resolve single link to an absolute URL #}
{%- set _link_url = null -%}
{%- if single_link -%}
  {%- set _u = single_link.url ~ '' -%}
  {%- if _u starts with 'http' -%}
    {%- set _link_url = _u -%}
  {%- elseif _u starts with '/' -%}
    {%- set _link_url = site_base ~ _u -%}
  {%- endif -%}
{%- endif -%}

{# Action type: only emit potentialAction when explicitly configured with a
   non-ReadAction type; otherwise the link is a plain url property #}
{%- set _action_type = (schema_action_type and schema_action_type != 'ReadAction') ? schema_action_type : null -%}

{%- if _name or _description -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  {%- if _name %}
  "name": {{ _name|json_encode|raw }},
  {%- endif %}
  {%- if _description %}
  "description": {{ _description|json_encode|raw }},
  {%- endif %}
  {%- if _link_url and not _action_type %}
  "url": {{ _link_url|json_encode|raw }},
  {%- endif %}
  "provider": {
    "@type": "CollegeOrUniversity",
    "name": {{ site_name|default('University of Colorado')|json_encode|raw }},
    "url": "https://www.cu.edu"
  }
  {%- if _link_url and _action_type -%}
  ,
  "potentialAction": {
    "@type": {{ _action_type|json_encode|raw }},
    "actionStatus": "https://schema.org/PotentialActionStatus",
    "target": {{ _link_url|json_encode|raw }}
  }
  {%- endif %}
}
</script>
{%- endif -%}

{# Only reference the title via aria-labelledby when the title actually
   renders (label present / "Display title" on). Otherwise the reference
   points to a non-existent id — a broken-ARIA WCAG failure. No label = a
   plain (non-landmark) section, which is correct. #}
{%- set block_attributes = attributes
  |without('id', 'role', 'aria-label', 'aria-labelledby')
  .setAttribute('id', unique_id)
  .addClass(basic_classes)
  .setAttribute('data-component', 'basic-block') -%}
{%- if label -%}
  {%- set block_attributes = block_attributes.setAttribute('aria-labelledby', title_id) -%}
{%- endif -%}
<section{{ block_attributes }}>

  {%- apply spaceless -%}

  {{- title_prefix -}}
  {{- title_suffix -}}

  {# Media Section #}
  {%- if card_image -%}
    {%- import '@cua_theme/component/macros/card_image.html.twig' as cardImageMacros -%}
    {{- cardImageMacros.render_card_image(card_image, position_container, text_alignment, text_color, image_size, visibility, content, links) -}}
  {%- elseif icon -%}
    {%- import '@cua_theme/component/macros/card_icon.html.twig' as iconMacros -%}
    {{- iconMacros.render_icon(icon, icon_size, icon_color, padding, position_container, text_alignment) -}}
  {%- endif -%}

  {# Heading Section #}
  {%- if label -%}
    {{- titleMacros.render_title(
      label,
      title_prefix,
      title_suffix,
      center_content,
      text_alignment,
      text_color,
      padding,
      false,
      [],
      '',
      'id="' ~ title_id ~ '"'
    ) -}}
  {%- endif -%}

  {# Main Content Section #}
  {%- if content -%}
    {%- import '@cua_theme/component/macros/card_body.html.twig' as bodyMacros -%}
    <div class="card-body-wrapper g-0">
      {{- bodyMacros.render_body(content, padding, text_color, text_alignment)|trim -}}
    </div>
  {%- endif -%}

  {# Action Section (Footer) #}
  {%- if links -%}
    {%- if single_link -%}
      {%- set outline_class = outline ? 'btn-outline-' ~ button_color : 'btn-' ~ button_color -%}
      {%- set link_classes = ['card-link', 'btn', outline_class, 'text-decoration-none', 'p-2', 'mt-3']|filter(v => v)|join(' ') -%}
      <div class="card-footer bg-transparent border-0 d-flex container mb-5">
        <a href="{{ single_link.url ?: '#' }}"
           class="{{ link_classes }}"
           data-ga-event="basic_block_link"
           data-ga-category="basic_block"
           data-ga-action="{{ single_link.title|default(label)|striptags|trim|e }}"
           data-ga-component-id="{{ unique_id }}">
          {{- single_link.title|default('Learn More') -}}
        </a>
      </div>
    {%- else -%}
      {%- import '@cua_theme/component/macros/card_footer.html.twig' as cardFooterMacros -%}
      {%- set ga_attributes = {
        'data-ga-event':        'basic_block_link',
        'data-ga-category':     'basic_block',
        'data-ga-component-id': unique_id,
      } -%}
      {{- cardFooterMacros.render_card_footer(links, container_size, color_background, position_container, text_alignment, padding, outline, button_color, button_layout, false, false, ga_attributes) -}}
    {%- endif -%}
  {%- endif -%}

  {%- endapply -%}
</section>