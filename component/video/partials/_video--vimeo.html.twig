{# _video--vimeo.html.twig #}

{% set schema_name = label|striptags|trim ?: 'Video' %}

<div itemscope itemtype="https://schema.org/VideoObject">

  <meta itemprop="name" content="{{ schema_name }}">
  <meta itemprop="embedUrl" content="https://player.vimeo.com/video/{{ video }}">

  <div class="video-embed">
    <div class="video-responsive">
      <iframe
        title="{{ schema_name }}"
        src="https://player.vimeo.com/video/{{ video }}"
        frameborder="0"
        allow="autoplay; fullscreen; picture-in-picture"
        allowfullscreen>
      </iframe>
    </div>
  </div>

  {% if transcript_url %}
    <p class="video-transcript-link">
      <a href="{{ transcript_url }}" class="small">
        View video transcript
      </a>
    </p>
  {% endif %}

</div>