{#-
  =============================================================================
  PARTIAL: YouTube Video
  SCHEMA STRATEGY:
    - Microdata removed — JSON-LD handled in the parent block template
    - This partial is responsible for the embed only
    - youtube-nocookie.com is correct for GDPR/privacy compliance
  =============================================================================
-#}
{%- set schema_name = label|striptags|trim ?: 'Video' -%}
{%- set video_markup = content.field_video_youtube|render -%}

<div class="video-embed">
  <div class="video-responsive">
    {{- video_markup
      |replace({'title="Video"': 'title="' ~ schema_name ~ '"'})
      |raw -}}
  </div>
</div>

{%- if transcript_url -%}
  <p class="video-transcript-link">
    <a href="{{ transcript_url }}" class="small">
      {{- 'View video transcript'|t -}}
    </a>
  </p>
{%- endif -%}