{# 
  =============================================================================
  COMPONENT: Call to Action (CTA)
  COMPLIANCE: WCAG 2.2 AA / Section 508 / Schema.org (configurable type)
  SCHEMA STRATEGY (2026-06):
    - JSON-LD via <script> block — preferred by Google & AI crawlers over Microdata
    - Each block is a standalone schema node (Layout Builder blocks are isolated;
      no parent template has visibility across siblings, so ItemList is not valid here)
    - ItemList is only appropriate in view-based templates (e.g. give-now-grid)
      where all items are known at render time
    - TYPE SELECTION:
        1. schema_action_type from block config, if set, always wins
           (except ReadAction, which is remapped — legacy configs may carry it)
        2. default: WebPageElement — ReadAction is NEVER emitted; it is a
           ConsumeAction subtype and Google requires expectsAcceptanceOf
           (Offer) on all ConsumeActions, treating them as paid-content markup
    - No URL-based type detection — editors set DonateAction explicitly on
      giving CTAs via block config; the template never guesses intent
    - actionStatus / agent only emitted for Action types; DonateAction also
      gets recipient referencing the sitewide #foundation node by @id
    - URLs always absolute: relative paths prefixed with site_base
      (base_url unavailable in this block template context)
    - Microdata attributes removed from HTML — no dual-format conflicts
  FIELD-VALUE NOTES (list fields store machine KEYS, not display labels):
    - flag field stores 'flag_on' / 'flag_off' — compare against keys, not labels
    - button_color may store 'hide_btn' — this is a sentinel meaning "no button";
      when set, the footer/button is removed from the DOM entirely
  =============================================================================
#}

{# ── Attach Library ─────────────────────────────────────────────────── #}
{{- attach_library('cua_theme/call-to-action') -}}

{# ── Unique ID Generation ─────────────────────────────────────────────────── #}
{%- set block_id = elements.content['#block_content'].id()|default(random(1000, 9999)) -%}
{%- set unique_id = ('cta-' ~ block_id)|replace({'_': '-', ':': '--'})|clean_class -%}

{# ── Animation Logic ──────────────────────────────────────────────────────── #}
{%- set raw_animation = prefers_reduced_motion ? [] : [
  'animate__animated',
  animation ?: null,
  animation_speed ?: null,
  animation_delay ?: null,
]|filter(v => v) -%}
{%- set data_animation = raw_animation|join(' ')|trim -%}

{# ── Class Merging ────────────────────────────────────────────────────────── #}
{%- set cta_classes = [
  'block',
  'call-to-action',
  'card',
  'rounded-0',
  'h-100',
  'position-relative',
  'block-' ~ configuration.provider|clean_class,
  'block-' ~ plugin_id|clean_class,
  (animation or animation_speed or animation_delay) ? 'animate-trigger' : null,
  color_background ?: 'bg-transparent',
  color_border ?: 'border-0',
  container_size,
  padding,
  margin,
  shadow,
  id ? 'block--' ~ id|clean_class : null,
]|merge(utility_classes ?: [])|filter(v => v)|join(' ') -%}

{# ── Link & Wrap Logic ────────────────────────────────────────────────────── #}
{%- set links_count = links|length -%}
{%- set single_link = (links_count == 1) ? links|first : null -%}
{%- set wrap_entire_card = single_link and not content_contains_other_links -%}

{# ── Flag State ───────────────────────────────────────────────────────────── #}
{# List field stores the machine key 'flag_on' (not the label 'Flag On').
   Normalized to also tolerate case/whitespace and common truthy values. #}
{%- set flag_is_on = flag|lower|trim in ['flag_on', 'flag on', 'on', '1', 'true'] -%}

{# ── Button Visibility ────────────────────────────────────────────────────── #}
{# 'hide_btn' is a sentinel value meaning "no button" — when set, the footer
   and its button are removed from the DOM entirely (not just visually hidden). #}
{%- set hide_button = button_color|lower|trim == 'hide_btn' -%}

{# ── Attributes ───────────────────────────────────────────────────────────── #}
{%- set attributes = attributes
  .setAttribute('id', unique_id)
  .addClass(cta_classes)
  .setAttribute('role', 'region')
  .setAttribute('data-animation-classes', data_animation)
  .setAttribute('data-component', 'call-to-action-card') -%}

{%- if label -%}
  {%- set attributes = attributes.setAttribute('aria-labelledby', unique_id ~ '-label') -%}
{%- else -%}
  {%- set attributes = attributes.setAttribute('aria-label', 'Call to Action') -%}
{%- endif -%}

{# ── JSON-LD Schema ───────────────────────────────────────────────────────── #}
{%- set site_base = 'https://www.giving.cu.edu' -%}

{# Resolve the schema URL to absolute. single_link.url may be an external
   https URL or a site-relative path from Layout Builder link fields. #}
{%- set schema_url = null -%}
{%- if single_link -%}
  {%- set _u = single_link.url ~ '' -%}
  {%- if _u starts with 'http' -%}
    {%- set schema_url = _u -%}
  {%- elseif _u starts with '/' -%}
    {%- set schema_url = site_base ~ _u -%}
  {%- endif -%}
{%- endif -%}

{# Type resolution: explicit schema_action_type config wins; default is
   WebPageElement. ReadAction is remapped — it is a ConsumeAction subtype
   and Google requires expectsAcceptanceOf (Offer) on all ConsumeActions.
   Editors set DonateAction on giving CTAs via the block config. #}
{%- if schema_action_type and schema_action_type != 'ReadAction' -%}
  {%- set schema_type = schema_action_type -%}
{%- else -%}
  {%- set schema_type = 'WebPageElement' -%}
{%- endif -%}
{%- set schema_is_action = schema_type ends with 'Action' -%}

{%- set schema_name = (single_link.title ?: label)|striptags|trim -%}
{%- set schema_description = label|striptags|trim -%}
{%- if not schema_description -%}
  {%- set _block_entity = elements.content['#block_content'] -%}
  {%- if _block_entity.body.value -%}
    {%- set schema_description = _block_entity.body.value|striptags|trim|slice(0, 300) -%}
  {%- endif -%}
{%- endif -%}

{%- if schema_name or schema_description -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": {{ schema_type|json_encode|raw }},
  {%- if schema_name %}
  "name": {{ schema_name|json_encode|raw }},
  {%- endif %}
  {%- if schema_url %}
  "url": {{ schema_url|json_encode|raw }},
  {%- endif %}
  {%- if schema_description %}
  "description": {{ schema_description|json_encode|raw }},
  {%- endif %}
  {%- if schema_is_action %}
  "actionStatus": "https://schema.org/PotentialActionStatus",
  {%- if schema_type == 'DonateAction' %}
  "recipient": {
    "@id": "https://www.giving.cu.edu/#foundation"
  },
  {%- endif %}
  "agent": {
    "@type": "CollegeOrUniversity",
    "name": {{ site_name|default('University of Colorado')|json_encode|raw }},
    "url": "https://www.cu.edu"
  }
  {%- else %}
  "isPartOf": {
    "@type": "WebPage",
    "url": {{ (url('<current>')|render)|json_encode|raw }}
  }
  {%- endif %}
}
</script>
{%- endif -%}

{# ═════════════════════════════════════════════════════════════════════════════
   TEMPLATE
   ═════════════════════════════════════════════════════════════════════════════ #}
<section{{ attributes }}>

  {{- title_prefix -}}
  {{- title_suffix -}}

  {%- apply spaceless -%}

  {# ── Card Wrapper Link (single link = entire card clickable) ────────────── #}
  {%- if wrap_entire_card -%}
    <a href="{{ single_link.url|default('#') }}"
       class="cta-card-link-wrapper text-decoration-none color-inherit"
       aria-label="{{ single_link.title|striptags|trim }}{% if label %} - {{ label|striptags|trim }}{% endif %}">
  {%- endif -%}

    {# ── Flag Badge — only renders when Flag On ─────────────────────────────
       NOTE: This entire block including both wrapper divs lives inside the
       flag_is_on check. Never split open/close divs across conditionals.
    ── #}
    {%- if flag_is_on -%}
      <div class="position-absolute start-0 top-0 z-1">
        {%- set flag_classes = [
          'flag-badge',
          'd-inline-flex',
          'align-items-center',
          'py-1',
          'px-2',
        ]|filter(v => v) -%}
        <div class="flag py-2 {{ flag_background }} {{ flag_classes|join(' ')|trim }}"
             style="width:max-content;white-space:nowrap;">
          {%- if icon -%}
            <i class="{{ icon }} {{ icon_size }} px-1"
               {% if icon_color %}style="color:{{ icon_color }}"{% endif %}
               aria-hidden="true"></i>
          {%- endif -%}
          {%- if flag_title -%}
            <span class="flag-title">{{- flag_title -}}</span>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    {# ── Media: Video / Image / Icon ────────────────────────────────────────
       Icon only renders here when flag is Off or N/A.
       When flag is On, icon is already rendered in the flag badge above.
    ── #}
    {%- if provider or card_image or (icon and not flag_is_on) -%}
      <figure class="cta-media mb-0" role="presentation">
        {%- if provider -%}
          {%- include '@cua_theme/component/video/partials/_video--master.html.twig' -%}
        {%- elseif card_image -%}
          {%- import '@cua_theme/component/macros/card_image.html.twig' as cardImageMacros -%}
          {{- cardImageMacros.render_card_image(card_image, position_container, text_alignment, text_color, image_size, visibility, content, true) -}}
        {%- elseif icon -%}
          {%- import '@cua_theme/component/macros/card_icon.html.twig' as iconMacros -%}
          <div class="pb-2">
            {{- iconMacros.render_icon(icon, icon_size, icon_color, padding, position_container, text_alignment) -}}
          </div>
        {%- endif -%}
      </figure>
    {%- endif -%}

    {# ── Caption ─────────────────────────────────────────────────────────── #}
    {%- if caption -%}
      {%- import '@cua_theme/component/macros/card_caption.html.twig' as captionMacros -%}
      {{- captionMacros.render_caption(caption, padding, text_color, text_alignment) -}}
    {%- endif -%}

    {# ── Title / Label ───────────────────────────────────────────────────── #}
    {%- if label -%}
      <header class="card-header border-0 pt-2 {{ padding }}">
        <h3 id="{{ unique_id }}-label"
            class="display-4 card-title title {{ text_color }} {{ text_alignment }}">
          {{- label|trim -}}
        </h3>
      </header>
    {%- endif -%}

    {# ── Body Content ────────────────────────────────────────────────────── #}
    {%- if content -%}
      {%- import '@cua_theme/component/macros/card_body.html.twig' as bodyMacros -%}
      <div class="cta-text lead {{ padding }} {{ text_color }}">
        {{- bodyMacros.render_body(content, text_color, text_alignment)|trim -}}
      </div>
    {%- endif -%}

    {# ── Single Link Footer ──────────────────────────────────────────────────
       Suppressed entirely when the editor selects "hide button" (hide_btn).
       The card remains clickable via the wrapper link in wrap_entire_card mode.
    ── #}
    {%- if single_link and not hide_button -%}
      <footer class="card-footer d-flex flex-wrap {{ container_size }} {{ position_container }} {{ text_alignment }} {{ padding }} mb-5 border-0 bg-transparent mt-auto">
        {%- set outline_class = outline ? 'btn-outline-' ~ button_color : 'btn-' ~ button_color -%}
        {%- if wrap_entire_card -%}
          <span class="card-link btn {{ outline_class }} text-decoration-none p-2 mt-3" aria-hidden="true" style="display:inline-block;">
            {{- single_link.title -}}
          </span>
        {%- else -%}
          <a href="{{ single_link.url }}" class="card-link btn {{ outline_class }} text-decoration-none p-2 mt-3">
            {{- single_link.title -}}
          </a>
        {%- endif -%}
      </footer>
    {%- endif -%}

    {# ── Multi-Link Footer ───────────────────────────────────────────────────
       Also respects the hide_button sentinel.
    ── #}
    {%- if links_count > 1 and not hide_button -%}
      {%- import '@cua_theme/component/macros/card_footer.html.twig' as cardFooterMacros -%}
      {{- cardFooterMacros.render_card_footer(links, container_size, color_background, position_container, text_alignment, padding, outline, button_color, button_layout, false, false) -}}
    {%- endif -%}

  {%- if wrap_entire_card -%}
    </a>
  {%- endif -%}

  {%- endapply -%}

</section>