{# see https://www.drupal.org/project/drupal/issues/953034#comment-14192130 #}
{% set sidebar_first_exists = page.sidebar_first|render|striptags('<img><video><audio><drupal-render-placeholder>')|trim is not empty %}
{% set sidebar_second_exists = page.sidebar_second|render|striptags('<img><video><audio><drupal-render-placeholder>')|trim is not empty %}

<div id="page-wrapper">
	<div
		id="page">

		{# Header #}
		{% include '@cua_theme/templates/layout/header/header.html.twig' %}

		{# Main Content #}
		<div id="main-wrapper" class="layout-main-wrapper pb-5 clearfix">
			{% block content %}
				<div id="main" class="{{ container }}">

					<div class="card-body flex-column card-text lead g-0 clearfix">
						<h1 class="cu-line g-0 m-0 p-0">
							{{'FAQs'|t}}
						</h1>
					</div>

				{# Initialize array #}
				{% set _jsonld_items = [] %}

				{# Give Online #}
				{% set _action = {
				'@type': 'DonateAction',
				'name': 'Give Online'|t,
				'description': 'The easy way to support CU via credit card, payment app, or bank transfer.'|t,
				'target': 'https://giveto.cu.edu/funds/?a=8403519'
				} %}
				{% set _jsonld_items = _jsonld_items|merge([{
				'@type': 'ListItem',
				'position': _jsonld_items|length + 1,
				'item': _action
				}]) %}

				{# Give by Mail #}
				{% set _action = {
				'@type': 'DonateAction',
				'name': 'Give by Mail'|t,
				'description': 'Mail a completed donation form with check payable to University of Colorado Foundation.'|t,
				'recipient': {
					'@type': 'CollegeOrUniversity',
					'name': 'University of Colorado Foundation',
					'address': {
					'@type': 'PostalAddress',
					'streetAddress': 'P.O. Box 561690',
					'addressLocality': 'Denver',
					'addressRegion': 'CO',
					'postalCode': '80256-1690'
					}
				}
				} %}
				{% set _jsonld_items = _jsonld_items|merge([{
				'@type': 'ListItem',
				'position': _jsonld_items|length + 1,
				'item': _action
				}]) %}

				{# Give by Phone #}
				{% set _action = {
				'@type': 'DonateAction',
				'name': 'Give by Phone'|t,
				'description': 'All major credit cards accepted.'|t,
				'target': 'tel:3035411290',
				'instrument': 'Credit Card'
				} %}
				{% set _jsonld_items = _jsonld_items|merge([{
				'@type': 'ListItem',
				'position': _jsonld_items|length + 1,
				'item': _action
				}]) %}

				{# Output JSON-LD #}
				{% if _jsonld_items|length > 0 %}
				{% set _jsonld = {
					'@context': 'https://schema.org',
					'@type': 'ItemList',
					'name': 'Ways to Give'|t,
					'itemListOrder': 'https://schema.org/ItemListUnordered',
					'numberOfItems': _jsonld_items|length,
					'itemListElement': _jsonld_items
				} %}

				<script type="application/ld+json">
					{{ _jsonld|json_encode|raw }}
				</script>
				{% endif %}

					<div class="row d-flex flex-column-reverse flex-md-row clearfix">

						{# Left Sidebar #}
						{% if sidebar_first_exists %}
							<div class="col-md-3 col-sm-12 mb-4 order-1 order-md-2 mt-4 mobile-padding">
								<aside class="section" role="complementary">
									{{ page.sidebar_first }}
								</aside>
							</div>
						{% endif %}

						{# Page Content #}
						<main{{content_attributes}} class="col-md-9 col-sm-12 mb-4 order-2 order-md-1">
							<section class="section">

								<div class="row g-4 mb-5">
									<div class="col-12 col-md-4">
										<div class="p-4 h-100 border rounded">
											<h2 class="h5 mb-3">
												<i class="fa-solid fa-mobile-screen-button me-2" style="color:#cfb87c;" aria-hidden="true"></i>
												{{ 'Give Online'|t }}
											</h2>
											<p>
												{{ 'The easy way to support CU via credit card, payment app, or bank transfer.'|t }}
											</p>
											<a href="https://giveto.cu.edu/funds/?a=8403519" class="btn btn-primary mt-2">
												{{ 'Explore CU funds'|t }}
											</a>
										</div>
									</div>
									<div class="col-12 col-md-4">
										<div class="p-4 h-100 border rounded">
											<h2 class="h5 mb-3">
												<i class="fa-solid fa-envelope me-2" style="color:#cfb87c;" aria-hidden="true"></i>
												{{ 'Give by Mail'|t }}
											</h2>
											<p>
												{{ 'Mail a completed'|t }}
												<a href="https://www.giving.cu.edu/sites/default/files/2025-10/Full%20Sheet.pdf">
												{{ 'donation form'|t }} (PDF)
												<i class="fa-solid fa-download ms-1" aria-hidden="true"></i>
												</a>
												{{ 'with check payable to:'|t }}
											</p>
											<address class="mb-0">
												{{ 'University of Colorado Foundation'|t }}
												<br>
												P.O. Box 561690
												<br>
												Denver, CO 80256-1690
											</address>
										</div>
									</div>
									<div class="col-12 col-md-4">
										<div class="p-4 h-100 border rounded">
											<h2 class="h5 mb-3">
												<i class="fa-solid fa-phone me-2" style="color:#cfb87c;" aria-hidden="true"></i>
												{{ 'Give by Phone'|t }}
											</h2>
											<p>
												{{ 'All major credit cards accepted.'|t }}
											</p>
											<p class="fw-bold mb-1">
												303‑541‑1290
											</p>
											<p class="mb-0">
												{{ 'Monday–Friday, 9a–5p'|t }}
											</p>
										</div>
									</div>
								</div>


								{{ page.content }}
							</section>
						</main>

						{# Right Sidebar #}
						{% if sidebar_second_exists %}
							<div class="col-md-3 col-sm-12 mb-4 order-3 order-md-last">
								<aside class="section" role="complementary">
									{{ page.sidebar_second }}
								</aside>
							</div>
						{% endif %}

					</div>
				</div>
			{% endblock %}
		</div>

		{# Footer #}
		{% include '@cua_theme/templates/layout/footer/footer.html.twig' %}

	</div>
</div>