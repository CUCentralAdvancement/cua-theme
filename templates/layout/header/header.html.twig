{#
/**
 * @file
 * Theme override for the site header.
 *
 * Standards: WCAG 2.1 AA / Section 508, Bootstrap 5.3.
 *
 * Structure & constraints — check these before "simplifying":
 * - Landmarks: <header role="banner"> is the single banner. The only navigation
 *   landmarks are #navbar-main and the secondary-menu block (Drupal emits its
 *   own <nav>). The utility bar is deliberately a <div>, not a <nav>, so the
 *   logo/search controls don't sit inside a mislabelled nav landmark.
 * - Layout: the banner background is full-bleed (header#header sets the white
 *   background). The top bar and the main nav both use `.container-fluid px-3`
 *   so their edges align; only the search panel caps its content with
 *   `.container`.
 * - Load-bearing IDs: js/global.js reads #CollapseSearch (autofocus); CSS uses
 *   the element selector `nav#navbar-main`,
 *   so #navbar-main MUST stay a <nav>. #mainNavbarSupportedContent is the toggle
 *   target. The search <h2> (#search-heading) MUST stay OUTSIDE the collapse so
 *   the region keeps an accessible name while collapsed.
 * - Secondary menu is rendered twice. Desktop: the block placement
 *   (#block-cua-theme-secondarymenu — CSS targets that id). Mobile: the menu is
 *   rendered directly via drupal_menu() (Twig Tweak — a site-level composer
 *   dependency, not the theme's) inside hand-built wrappers carrying the same
 *   classes CSS targets.
 * - Branding: site_name passes through |e (Drupal translates upstream).
 * - Performance: the LCP logo uses fetchpriority="high" + eager loading. Both
 *   logo <img>s point at the same file, so the browser makes one high-priority
 *   request regardless of breakpoint — the mobile <img> needs no hints of its
 *   own.
 */
#}

<header id="header" class="header" role="banner" data-site-name="{{ site_name|e }}" data-site-section="header">

	{# site_slogan and show_slogan come from cua_theme_preprocess_page:
	   site_slogan = Basic site settings slogan; show_slogan = the
	   "Display site slogan" theme setting (Appearance → Settings). #}

	{# ── Utility / branding bar (full-width, matches body #main) ── #}
	<div class="container-fluid top-bar pt-2 mb-3 px-3">
		<div class="row align-items-center g-0">
			<div class="col mt-1 g-0">
				<div class="navbar l-header-top bg-white g-0" id="navbar-top" data-bs-theme="light">
					<div class="site-name-logo d-flex align-items-center w-100">

						{# Logo → home #}
						<a href="{{ url('<front>') }}" rel="home" class="site-branding__logo d-flex align-items-center text-decoration-none">
							<img class="d-none d-lg-block me-2" src="{{ base_path ~ directory ~ '/images/logo.svg' }}" alt="{{ 'University of Colorado'|t }}" width="375" height="76" fetchpriority="high" loading="eager"/>
							<img class="d-lg-none me-2" src="{{ base_path ~ directory ~ '/images/logo.svg' }}" alt="{{ 'University of Colorado'|t }}" width="260" height="53"/>
						</a>

						{# Utility cluster #}
						<div class="ms-auto d-flex align-items-center gap-2">

							{% if user.hasPermission('administer site configuration') %}
								<div class="d-none d-lg-flex align-items-center">
									<a href="/tutorials" class="btn btn-sm btn-admin-app">{{ 'Tutorials'|t }}</a>
								</div>
							{% endif %}
					
							{% if page.search %}
								<div class="search-button">
									<button class="search-icon btn btn-link p-0 text-dark" type="button" data-bs-toggle="collapse" data-bs-target="#CollapseSearch" aria-expanded="false" aria-controls="CollapseSearch" aria-label="{{ 'Toggle search'|t }}">
										<svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 36 36" aria-hidden="true" focusable="false">
											<circle cx="18" cy="18" r="17" fill="none" stroke="#c0c0c0" stroke-width="2"/>
											<path fill="#555555" transform="translate(11,11) scale(0.85)" d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
										</svg>
									</button>
								</div>
							{% endif %}

							{# Phone → contact page (the 'contact' view's page display).
							   path() follows the view's URL setting, so the link survives a
							   path change that would 404 a hardcoded alias. Desktop-only
							   (d-lg): it crowds the mobile header, and mobile users still
							   reach Contacts via the menu. #}
							<div class="phone-button d-none d-lg-flex">
								<a class="phone-icon btn btn-link p-0 text-dark" href="{{ path('view.contact.page_1') }}" aria-label="{{ 'Contact us'|t }}">
									<svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 36 36" aria-hidden="true" focusable="false">
										<circle cx="18" cy="18" r="17" fill="none" stroke="#c0c0c0" stroke-width="2"/>
										<path fill="#555555" transform="translate(11,11) scale(0.85)" fill-rule="evenodd" d="M1.885.511a1.745 1.745 0 0 1 2.61.163L6.29 2.98c.329.423.445.974.315 1.494l-.547 2.19a.68.68 0 0 0 .178.643l2.457 2.457a.68.68 0 0 0 .644.178l2.189-.547a1.75 1.75 0 0 1 1.494.315l2.306 1.794c.829.645.905 1.87.163 2.611l-1.034 1.034c-.74.74-1.846 1.065-2.877.702a18.6 18.6 0 0 1-7.01-4.42 18.6 18.6 0 0 1-4.42-7.009c-.362-1.03-.037-2.137.703-2.877z"/>
									</svg>
								</a>
							</div>

							{% if page.secondary_menu %}
								{# ms-lg-2 adds to the cluster's gap-2: 16px before the CTA vs
								   8px between the utility icons — spacing groups the icons and
								   sets Give Now apart. #}
								<div class="secondary-menu-container d-none d-lg-flex ms-lg-2">
									{{ page.secondary_menu }}
								</div>
							{% endif %}

							{# Mobile menu toggle — only meaningful when a primary menu exists #}
							{% if page.primary_menu %}
								<div class="d-lg-none">
									<button class="navbar-toggler collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbarSupportedContent" aria-controls="mainNavbarSupportedContent" aria-expanded="false" aria-label="{{ 'Toggle navigation'|t }}">
										<span class="navbar-toggler-icon"></span>
									</button>
								</div>
							{% endif %}

						</div>
					</div>
				</div>
			</div>
		</div>

		{# Search panel — toggled from the utility bar above.
		   The labelling <h2> stays OUTSIDE the collapse so the region keeps an
		   accessible name even while collapsed. #}
		{% if page.search %}
			<div class="container-fluid main-search" role="search">
				<div class="container">
					<h2 id="search-heading" class="visually-hidden">{{ 'Search site'|t }}</h2>
					<div class="collapse" id="CollapseSearch" role="region" aria-labelledby="search-heading">
						<div class="cua-search">
							{{ page.search }}
						</div>
					</div>
				</div>
			</div>
		{% endif %}

	</div>

	{# ── Primary navigation ─────────────────────────────────────────────
	   #navbar-main is styled via CSS (nav#navbar-main). #}
	{% if page.primary_menu %}
		<nav class="navbar l-header-bottom navbar-expand-lg g-0 m-0 border-top border-bottom" id="navbar-main" aria-label="{{ 'Main menu'|t }}">
			<div class="container-fluid px-3 g-0">

				{# Site slogan. Desktop: anchored left of the primary menu (Oomph
				   design), pushing the home icon + links right. Mobile: this row
				   sits outside the nav collapse, so it stays visible below the
				   branding bar — CSS centers it full-width. Toggled by the
				   "Display site slogan" theme setting (show_slogan). #}
				{% if site_slogan and show_slogan %}
					<div class="site-slogan d-flex align-items-center">{{ site_slogan }}</div>
				{% endif %}

				<div class="collapse navbar-collapse" id="mainNavbarSupportedContent">
					<div class="primary-menu-wrapper">
						{{ page.primary_menu }}
					</div>

					{% if page.secondary_menu %}
						<div class="secondary-menu-container d-lg-none my-3">
							{# Mobile copy of the secondary menu. Render the menu directly (not the
							   block) so it doesn't duplicate the desktop block's id/aria-labelledby
							   — fixes the WCAG 4.1.1 duplicate-id violation, while keeping the same
							   wrapper classes the CSS targets. #}
							<section class="row region region-secondary-menu">
								<nav class="block block-menu navigation menu--secondary-menu" aria-label="{{ 'Secondary menu'|t }}">
									{{ drupal_menu('secondary-menu') }}
								</nav>
							</section>
						</div>
					{% endif %}
				</div>
			</div>
		</nav>
	{% endif %}

</header>
