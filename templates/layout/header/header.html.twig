{#
/**
 * @file: header.html.twig
 * Standards: WCAG 2.1 AA / Section 508 Compliant.
 * * Key Constraints:
 * - Branding: site_name/slogan use |e (Drupal translates upstream).
 * - Accessibility: Search h2 (#search-heading) must remain outside the collapse div.
 * - Navigation: Mobile toggle sits in top bar but controls #navbar-main via ID.
 * - Performance: Secondary menu rendered once; repositioned via CSS/Bootstrap.
 */
#}

<header id="header" class="header" role="banner" aria-label="{{ 'Site header'|t }}">

    {#
      =========================================================================
      TOP BAR — Branding, Logo, and Mobile Toggle
      =========================================================================
      NOTE: This is a <div>, not a <nav>. The actual navigation landmarks are
      declared further down. Using a <nav> here created a redundant, unlabeled
      landmark that confused screen reader navigation.

      NOTE: "clearfix" is retained on the row. Drupal block output can contain
      floated elements. Without clearfix the row may collapse in height.
    #}
    <div class="container top-bar mb-2">
        <div class="row align-items-center clearfix g-0">
            <div class="col mt-3 g-0">
                <div class="navbar l-header-top navbar-light bg-white p-0 m-0" id="navbar-top">
                    <div class="container-fluid site-name-logo g-0">
                        <div class="container d-flex g-0">

                            {# --- CU Logo and Slogan --- #}
                            <div class="flex-shrink-1 d-flex align-items-center">
                                {#
                                  NOTE: rel="home" is the correct semantic value for a link
                                  back to the site front page. It is NOT for display text.
                                  The previous version incorrectly used rel as a label.

                                  NOTE: The anchor itself has no aria-label because each
                                  img below already carries a descriptive alt text.
                                #}
                                <a href="{{ url('<front>') }}"
                                   rel="home"
                                   class="site-branding__logo d-flex align-items-center text-decoration-none">

                                    {# Large-screen logo — hidden on mobile via d-none d-lg-block #}
                                    <img class="d-none d-lg-block me-2"
                                         src="{{ base_path ~ directory ~ '/images/logo.svg' }}"
                                         alt="{{ 'University of Colorado'|t }}"
                                         width="225" height="24"/>

                                    {# Small-screen logo — hidden on desktop via d-lg-none #}
                                    <img class="d-lg-none me-2"
                                         src="{{ base_path ~ directory ~ '/images/cu-mobile-logo.svg' }}"
                                         alt="{{ 'University of Colorado'|t }}"
                                         width="29" height="28"/>

                                    {#
                                      NOTE: site_slogan is output with |e (HTML-escape only).
                                      Do NOT use |t here. Drupal has already run this string
                                      through the translation system before passing it to the
                                      template. Calling |t again can double-translate or
                                      produce unexpected output if the value contains tokens.
                                    #}
                                    <span class="site-slogan text-nowrap">
                                        {{ site_slogan|e }}
                                    </span>

                                </a>
                            </div>

                            `{# --- Admin-Only Tutorials Link (Justified Right & Hidden on Mobile) --- #}
                           {% if user.hasPermission('administer site configuration') %}
								<div class="ms-auto d-none d-lg-flex align-items-center">
									<a href="/tutorials" class="btn btn-sm btn-admin-app">
										{{ 'Tutorials'|t }}
									</a>
								</div>
							{% endif %}

                            {#
                              --- Mobile Toggle Button ---
                              NOTE: This button MUST live inside the same <nav> landmark
                              as the content it controls (#mainNavbarSupportedContent).
                              Placing it outside the nav puts the button and its target
                              in separate landmark regions, which breaks the logical
                              relationship for assistive technology users.

                              Because navbar-top is a <div> and navbar-main is the true
                              <nav>, we render the toggle here visually but it is
                              semantically connected via aria-controls to the collapse
                              inside #navbar-main below. This is an acceptable Bootstrap
                              pattern as long as ids are unique and aria-controls matches.
                            #}
                            <div class="d-lg-none ms-auto">
                                <button class="navbar-toggler collapsed"
                                        type="button"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#mainNavbarSupportedContent"
                                        aria-controls="mainNavbarSupportedContent"
                                        aria-expanded="false"
                                        aria-label="{{ 'Toggle navigation'|t }}">
                                    <span class="navbar-toggler-icon"></span>
                                </button>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {#
      =========================================================================
      SEARCH FORM — Collapsible Region
      =========================================================================
      NOTE: The heading (#search-heading) that labels the region is placed
      OUTSIDE the collapse div. If the heading were inside the collapse,
      it would be hidden along with the panel when collapsed. A screen reader
      trying to announce the region label would then reference a hidden element,
      making the landmark label unreachable.

      NOTE: role="region" is required for aria-labelledby to be meaningful on
      a plain <div>. Without it, the div is not a landmark and assistive
      technology will not announce the label when the user enters it.

      NOTE: data-bs-parent has been intentionally omitted. The previous version
      referenced a class (.site-name-wrapper) that did not exist in the template,
      which silently broke accordion-style collapse behavior.
    #}
    {% if page.search %}
        <div class="container-fluid main-search bg-light border-top border-grey">
            <div class="container">

                {# Visible to screen readers always — outside the collapse #}
                <h2 id="search-heading" class="visually-hidden">{{ 'Search site'|t }}</h2>

                <div class="collapse"
                     id="CollapseSearch"
                     role="region"
                     aria-labelledby="search-heading">
                    <div class="cua-search">
                        {{ page.search }}
                    </div>
                </div>

            </div>
        </div>
    {% endif %}

    {#
      =========================================================================
      SITE NAME BAR — Single combined row (desktop + mobile)
      =========================================================================
      NOTE: The previous version had separate desktop (d-none d-lg-block) and
      mobile (d-block d-lg-none) versions of this bar, which duplicated the
      site_name output and the search toggle button. They have been merged into
      a single row. Responsive visibility is handled by Bootstrap utility classes
      on child elements only where needed.

      NOTE: site_name uses |e (HTML-escape) only — same reason as site_slogan.
      Drupal translates this upstream. Do not add |t.
    #}
    <div class="container-fluid bg-light border-bottom border-grey px-3 py-2">
        <div class="container d-flex justify-content-between align-items-center">

            {% if site_name %}
                <div class="site-slogan mx-2 my-2">
                    {{ site_name|e }}
                </div>
            {% endif %}

            {% if page.search %}
                <div class="search-button">
                    {#
                      NOTE: aria-label on the button describes the action.
                      The SVG carries aria-hidden="true" so screen readers
                      do not read out the raw SVG path data.
                      aria-expanded reflects the current collapsed/expanded
                      state and should be toggled via JS when the panel opens.
                    #}
                    <button class="search-icon btn btn-link p-0 text-dark"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#CollapseSearch"
                            aria-expanded="false"
                            aria-controls="CollapseSearch"
                            aria-label="{{ 'Open search'|t }}">
                        <svg xmlns="http://www.w3.org/2000/svg"
                             width="16" height="16"
                             fill="currentColor"
                             class="bi bi-search"
                             viewBox="0 0 16 16"
                             aria-hidden="true"
                             focusable="false">
                            <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
                        </svg>
                    </button>
                </div>
            {% endif %}

        </div>
    </div>

    {#
      =========================================================================
      MAIN NAVIGATION
      =========================================================================
      NOTE: aria-label is used directly on the <nav> element. This is simpler
      and cleaner than the aria-labelledby + visually-hidden <h2> pattern.
      The hidden h2 approach works but injects headings into the document
      outline that are not real content headings, which can confuse users
      navigating by heading level.

      NOTE: The secondary menu is rendered exactly ONCE here, using ms-lg-auto
      to push it to the right on desktop. The previous versions rendered it
      two or three times (desktop column, mobile div, sticky div), which caused
      duplicate ID errors if Drupal's block configuration output a hardcoded id
      attribute. One render + CSS repositioning is the correct approach.

      NOTE: navbar-expand-lg is kept so Bootstrap collapses the nav on mobile.
      The toggle button above (in the top bar) controls #mainNavbarSupportedContent
      via aria-controls. While ideally the button would be inside this <nav>,
      Bootstrap supports cross-element collapse via matching data-bs-target /
      aria-controls IDs. If your accessibility audit flags this, move the toggle
      button to inside this <nav> and hide it with d-lg-none.
    #}
    {% if page.primary_menu or page.secondary_menu %}
        <nav class="navbar l-header-bottom navbar-expand-lg shadow-sm g-0 m-0"
             id="navbar-main"
             aria-label="{{ 'Main menu'|t }}">
            <div class="container px-3 g-0">

                <div class="collapse navbar-collapse" id="mainNavbarSupportedContent">

                    {#
                      Sticky logo: shown via CSS when the header scrolls out of view.
                      aria-hidden="true" because it is purely decorative — the real
                      logo and its alt text are already present in the top bar above.
                      alt="" is set as well as a belt-and-suspenders measure for
                      browsers that ignore aria-hidden on img elements.
                    #}
                    <img class="sticky-show"
                         src="{{ base_path ~ directory ~ '/images/cu-mobile-logo.svg' }}"
                         alt=""
                         width="25" height="24"
                         aria-hidden="true"/>

                    {# Primary navigation — Drupal renders the <nav> and menu markup #}
                    {% if page.primary_menu %}
                        <div class="primary-menu-wrapper">
                            {{ page.primary_menu }}
                        </div>
                    {% endif %}

                    {#
                      Secondary menu — single render.
                      ms-lg-auto pushes it to the far right on desktop (lg+).
                      On mobile it falls naturally below the primary menu in the
                      expanded collapse panel.

                      NOTE: If your Drupal block for secondary_menu is configured
                      to output a hardcoded HTML id attribute, disable that in the
                      block's admin settings to prevent a duplicate ID if this
                      region ever appears elsewhere on the page.
                    #}
                    {% if page.secondary_menu %}
                        <div class="secondary-menu-container ms-lg-auto">
                            {{ page.secondary_menu }}
                        </div>
                    {% endif %}

                </div>
            </div>
        </nav>
    {% endif %}

</header>