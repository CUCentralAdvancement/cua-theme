{#
/**
 * @file: header.html.twig
 * Standards: WCAG 2.1 AA / Section 508 Compliant.
 * Key Constraints:
 * - Branding: site_name/slogan use |e (Drupal translates upstream).
 * - Accessibility: Search h2 (#search-heading) must remain outside the collapse div.
 * - Navigation: Mobile toggle sits in top bar but controls #navbar-main via ID.
 * - Performance: Secondary menu rendered once; repositioned via CSS/Bootstrap.
 */
#}

<style>
/* anchor */
.menu-content-wrapper .nav.navbar-nav > li.nav-item:first-child > a.nav-link {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 2rem;
  height: 2rem;
  padding: 0;
  font-size: 0; /* hide link text visually */
}

/* icon on top */
.menu-content-wrapper .nav.navbar-nav > li.nav-item:first-child > a.nav-link::before {
  content: "\f015";
  font-family: "Font Awesome 6 Free";
  font-weight: 900;               /* solid */
  font-style: normal;
  speak: none;
  display: inline-block;
  font-size: 1rem;                /* visible icon size */
  line-height: 1;
  color: #fff;
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
  z-index: 2;
}

/* hover background behind icon */
.menu-content-wrapper .nav.navbar-nav > li.nav-item:first-child > a.nav-link::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  width: 2.2rem;
  height: 2.2rem;
  transform: translate(-50%, -50%);
  border-radius: 0.35rem;
  background: transparent;
  z-index: 1;
  transition: background-color .16s ease;
}

/* hover states */
.menu-content-wrapper .nav.navbar-nav > li.nav-item:first-child > a.nav-link:hover::after {
  background: #c9c9c9;
}
.menu-content-wrapper .nav.navbar-nav > li.nav-item:first-child > a.nav-link:hover::before {
  color: #222;
}

.menu-content-wrapper .nav.navbar-nav > li.nav-item:first-child > a.nav-link {
    margin: .6rem 0 0;
}

header #search-block-form {
    border-bottom: 2px solid var(--cua-black);
}

span.site-slogan.text-nowrap {
    color: #ffffff !important;
}

.cu-background-black {
   color: #ffffff !important;
   background-color: black !important;
}

header#header {
    background:  black !important;
}

.header #block-cua-theme-secondarymenu .nav-item:last-child .nav-link {
    background: var(--cua-gold);
    color: var(--cua-black) !important;
    font-weight: 700;
    font-size: .85rem !important;
    padding: .5rem 1rem !important;
    border-radius: 1rem !important;
    border-right: 1px solid black !important;
}

.header #block-cua-theme-secondarymenu .nav-item:last-child .nav-link  svg.ext {
    display: none !important;
}

header .nav-item:first-child {
    border-right: none;
}

button.search-icon {
    padding: .3rem !important;
    margin: .2rem 0 0;
}

nav#navbar-main {
    background: #333332 !important;
}

header .nav-item {
    border-right: 0 solid var(--cua-gray-500);
}

</style>

<header id="header" class="header cu-background-black" role="banner"
  aria-label="{{ 'Site header'|t }}"
  data-site-name="{{ site_name|e }}"
  data-site-section="header">

  <div class="container cu-background-black top-bar mb-2">
    <div class="row align-items-center clearfix g-0">
      <div class="col mt-2 g-0">
        <nav class="navbar l-header-top navbar-light bg-white p-0 m-0"
          id="navbar-top"
          aria-label="{{ 'Site utility bar'|t }}">
          <div class="container-fluid site-name-logo g-0">
            <div class="container d-flex cu-background-black g-0">

              <div class="flex-shrink-1 d-flex align-items-center">
                <a href="{{ url('<front>') }}"
                  rel="home noopener"
                  class="site-branding__logo d-flex align-items-center text-decoration-none">
                  <img
                    class="d-none d-lg-block me-2"
                    src="{{ base_path ~ directory ~ '/images/logo-new-white.svg' }}"
                    alt="{{ 'University of Colorado'|t }}"
                    width="225"
                    height="24"
                    fetchpriority="high"
                    loading="eager"/>
                  <img
                    class="d-lg-none me-2"
                    src="{{ base_path ~ directory ~ '/images/cu-mobile-logo.svg' }}"
                    alt="{{ 'University of Colorado'|t }}"
                    width="29"
                    height="28"/>
                  <span class="site-slogan text-nowrap">
                    {{ site_slogan|e }}
                  </span>
                </a>
              </div>

              {% if user.hasPermission('administer site configuration') %}
                <div class="ms-auto d-none d-lg-flex align-items-center">
                  <a href="/tutorials" class="btn btn-sm btn-admin-app">
                    {{ 'Tutorials'|t }}
                  </a>
                </div>
              {% endif %}

              {% if page.secondary_menu %}
               {% if page.secondary_menu %}
                  <div class="secondary-menu-container ms-lg-auto mx-4">
                    {{ page.secondary_menu }}
                  </div>
                {% endif %}
              {% endif %}

                {% if page.search %}
        <div class="search-button">
          <button
            class="search-icon btn btn-link p-0 text-dark"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#CollapseSearch"
            aria-expanded="false"
            aria-controls="CollapseSearch"
            aria-label="{{ 'Open search'|t }}">
            <svg
              xmlns="https://www.w3.org/2000/svg"
              width="16"
              height="16"
              fill="currentColor"
              class="bi bi-search"
              viewBox="0 0 16 16"
              aria-hidden="true"
              focusable="false">
              <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
            </svg>
          </button>
        </div>
      {% endif %}

              <div class="d-lg-none ms-auto">
                <button
                  class="navbar-toggler collapsed"
                  type="button"
                  data-bs-toggle="collapse"
                  data-bs-target="#mainNavbarSupportedContent"
                  aria-controls="mainNavbarSupportedContent navbar-main"
                  aria-expanded="false"
                  aria-label="{{ 'Toggle navigation'|t }}">
                  <span class="navbar-toggler-icon"></span>
                </button>
              </div>

            </div>
          </div>
        </nav>

      </div>
    </div>
  </div>

   {% if page.search %}
    <div class="container-fluid main-search"
      role="search">
      <div class="container">
        <h2 id="search-heading" class="visually-hidden">
          {{ 'Search site'|t }}
        </h2>
        <div class="collapse" id="CollapseSearch" role="region" aria-labelledby="search-heading">
          <div class="cua-search">
            {{ page.search }}
          </div>
        </div>
      </div>
    </div>
  {% endif %}


  {% if page.primary_menu %}
    <nav class="navbar l-header-bottom navbar-expand-lg shadow-sm g-0 m-0"
      id="navbar-main"
      aria-label="{{ 'Main menu'|t }}">
      <div class="container px-3 g-0">
        <div class="collapse navbar-collapse" id="mainNavbarSupportedContent">
          <img
            class="sticky-show"
            src="{{ base_path ~ directory ~ '/images/cu-mobile-logo.svg' }}"
            alt=""
            width="25"
            height="24"
            aria-hidden="true"
            role="presentation"/>

          {% if page.primary_menu %}
            <div class="primary-menu-wrapper">
              {{ page.primary_menu }}
            </div>
          {% endif %}

        </div>
      </div>
    </nav>
  {% endif %}

</header>
