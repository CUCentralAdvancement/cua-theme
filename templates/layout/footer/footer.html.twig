{#
================================================================================
  footer.html.twig
================================================================================
#}
{%- apply spaceless -%}
<footer class="site-footer mt-auto" role="contentinfo" aria-label="{{ 'University of Colorado site footer'|t }}">
  <div id="site-footer-top" class="container pt-3">

    {%- if page.footer_first or page.footer_second or page.footer_third or page.footer_fourth or page.footer_fifth -%}
      <div class="row g-0">

        {%- if page.footer_first -%}
          <div class="col-md-4 col-sm-6 px-2 d-flex flex-column gap-4 footer-address">

            <section aria-labelledby="footer-foundation-heading">

              <div class="cua-name-title">
                <h3 id="footer-foundation-heading" class="mb-3 text-white">
                  {{ 'University of Colorado Foundation'|t }}
                  <span class="visually-hidden">{{ 'contact information'|t }}</span>
                </h3>
              </div>

              <div class="cua-address mb-2 px-2 text-white">
                1800 Grant Street, Suite 725<br>
                Denver, CO 80203
              </div>

              <div class="cua-phone mb-2 px-3 pt-2 text-gold">
                <a class="link-cua" href="tel:+13038137935" aria-label="{{ 'Call 303-813-7935'|t }}">
                  <i class="fa-solid fa-phone pe-1" aria-hidden="true"></i>
                  303-813-7935
                </a>
              </div>

              <div class="cua-map mb-2 px-3 text-gold">
                <a class="link-cua px-1" href="https://maps.app.goo.gl/G3RfovjWdKMCJZw6A" aria-label="{{ 'Open map and directions to University of Colorado Foundation'|t }}">
                  <i class="fa-solid fa-map pe-1" aria-hidden="true"></i>
                  {{ 'Directions'|t }}
                </a>
              </div>

              <div class="cua-charity-navigator mt-3 px-2">
                <a href="https://www.charitynavigator.org/ein/846049811"
                   target="_blank" rel="noopener"
                   aria-label="{{ 'University of Colorado Foundation — Four-Star rated by Charity Navigator (opens in a new tab)'|t }}">
                  <img src="{{ base_path ~ directory ~ '/images/4star-ratingbadge.png' }}"
                       width="103" height="103" alt="" loading="lazy">
                </a>
              </div>

            </section>

            <section aria-labelledby="footer-advancement-heading">

              <div class="cua-name-title">
                <h3 id="footer-advancement-heading" class="mb-3 text-white">
                  {{ 'University of Colorado Advancement'|t }}
                  <span class="visually-hidden">{{ 'contact information'|t }}</span>
                </h3>
              </div>

              <div class="cua-address mb-3 px-2 text-white">
                1800 Grant Street, Suite 215<br>
                Denver, CO 80203
              </div>

              <div class="cua-email mb-2 px-3">
                <a class="link-cua" href="mailto:giving@cu.edu" aria-label="{{ 'Send email to giving@cu.edu'|t }}">
                  <i class="fa-solid fa-envelope me-2" aria-hidden="true"></i>
                  giving@cu.edu
                </a>
              </div>

            </section>

          </div>
        {%- endif -%}

        {#- footer_second: bare column. If the block placed here has its own
            heading, this is fine. If not, wrap it in a <section aria-labelledby>
            with a visually-hidden h3 to match the other regions. -#}
        {%- if page.footer_second -%}
          <div class="col-md-3 col-sm-6 px-2">
            {{ page.footer_second }}
          </div>
        {%- endif -%}

        {%- if page.footer_third -%}
          <section class="col-md-3 col-sm-6 px-2" aria-labelledby="footer-resources-heading">
            <h3 id="footer-resources-heading" class="visually-hidden">
              {{ 'Resources for Students and Faculty'|t }}
            </h3>
            {{- page.footer_third -}}
          </section>
        {%- endif -%}

        {%- if page.footer_fourth -%}
          <section class="col-md-2 col-sm-6 px-2" aria-labelledby="footer-quick-links-heading">
            <h3 id="footer-quick-links-heading" class="visually-hidden">
              {{ 'Quick Navigation Links'|t }}
            </h3>
            {{ page.footer_fourth }}
          </section>
        {%- endif -%}

        {%- if page.footer_fifth -%}
          <section class="col-12 make-a-gift g-0 my-2" aria-labelledby="footer-support-heading">
            <h3 id="footer-support-heading" class="visually-hidden">
              {{ 'Support the University'|t }}
            </h3>
            {{ page.footer_fifth }}
          </section>
        {%- endif -%}

      </div>
    {%- endif -%}

  </div>

  <div id="site-footer-bottom" class="container-fluid bg-pure-black px-5 pb-2">
    <div class="row">

      <div class="col-12 mt-4 mb-3 d-flex align-items-center justify-content-center cu-logo-section">
        <img class="img-fluid" src="{{ base_path ~ directory ~ '/images/cua-logo-white.svg' }}" alt="{{ 'University of Colorado logo'|t }}" width="500" height="140" loading="lazy"/>
      </div>

      {%- if page.footer_sixth -%}
        <section class="col-12 d-flex align-items-center justify-content-center" aria-labelledby="footer-additional-info-heading">
          <h3 id="footer-additional-info-heading" class="visually-hidden">
            {{ 'Legal and Additional Information'|t }}
          </h3>
          {{ page.footer_sixth }}
        </section>
      {%- endif -%}

      <div class="col-12 border-top border-secondary d-flex align-items-center justify-content-center">
        <p class="mt-2 mb-3 fw-bold text-light">
          &copy;
          {{ 'now'|date('Y') }}
          <a href="https://regents.cu.edu" rel="noopener" target="_blank" class="link-light link-underline-opacity-0 px-2" aria-label="{{ 'Regents of the University of Colorado (opens in a new tab)'|t }}">
            {{ 'Regents of the University of Colorado'|t }}
          </a>
        </p>
      </div>

    </div>
  </div>
</footer>
{%- endapply -%}
