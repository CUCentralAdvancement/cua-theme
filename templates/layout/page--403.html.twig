{#
  page--403.twig
#}
<div id="page-wrapper">
    <div id="page">

        {# Header #}
        {% include '@cua_theme/templates/layout/header/header.html.twig' %}

        {# Main Content #}
        <div id="main-wrapper" class="layout-main-wrapper pb-5 clearfix">
            {% block content %}
                <div id="main" class="{{ container }}">
                    <div class="row d-flex flex-column-reverse flex-md-row clearfix">

                        {# Page Content #}
                        <main{{ content_attributes }} class="col-md-9 col-sm-12 mb-4 order-2 order-md-1">
                            <section class="section">
                                <div class="access-denied my-5 py-5">
                                    <h1 class="title mb-3">{{ 'Login Required'|t }}</h1>
                                    <p class="w-75">
                                        {{ 'In order to access the fund manager resources, click the "Login" button at the bottom of the page. To request access, email'|t }}
                                        <a href="mailto:Accounting@cufund.org">{{ 'Accounting@cufund.org.'|t }}</a>
                                    </p>
                                </div>
                            </section>
                        </main>

                    </div>
                </div>
            {% endblock %}
        </div>

        {# Footer #}
        {% include '@cua_theme/templates/layout/footer/footer.html.twig' %}

    </div>
</div>


