<!DOCTYPE html>
<html{{ html_attributes }}>

  <head>

    <link rel="preconnect" href="https://www.googletagmanager.com">
    <link rel="dns-prefetch" href="https://www.googletagmanager.com">

    <script async src="https://www.googletagmanager.com/gtm.js?id=GTM-KBWW4MVB"></script>

    <link rel="preload"
      href="/themes/contrib/cua_theme/fonts/roboto-condensed-v31-latin-regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin>
    <link rel="preload"
      href="/themes/contrib/cua_theme/fonts/roboto-v51-latin-regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin>

    <head-placeholder token="{{ placeholder_token|raw }}">

    <title>{{ head_title|safe_join(' | ') }}</title>

    <css-placeholder token="{{ placeholder_token|raw }}">
    <js-placeholder token="{{ placeholder_token|raw }}">

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": ["Organization", "NGO"],
      "@id": "https://www.giving.cu.edu/#organization",
      "name": "University of Colorado Foundation",
      "alternateName": "CU Foundation",
      "url": "https://www.giving.cu.edu/",
      "description": "Founded in 1967, the University of Colorado Foundation manages over $3.2 billion in assets to support education, research, and community engagement across CU's four campuses.",
      "foundingDate": "1967",
      "taxID": "84-6049811",
      "nonprofitStatus": "Nonprofit501c3",
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.giving.cu.edu/themes/contrib/cua_theme/images/logo.svg",
        "width": 225,
        "height": 24
      },
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "1800 Grant Street, Suite 725",
        "addressLocality": "Denver",
        "addressRegion": "CO",
        "postalCode": "80203",
        "addressCountry": "US"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+1-303-813-7935",
        "email": "gifts@cufund.org",
        "contactType": "donor services",
        "areaServed": "US"
      },
      "parentOrganization": {
        "@type": "CollegeOrUniversity",
        "name": "University of Colorado",
        "url": "https://www.cu.edu/"
      },
      "department": {
        "@type": "Organization",
        "@id": "https://www.giving.cu.edu/#advancement",
        "name": "Central CU Advancement",
        "url": "https://www.giving.cu.edu/about-us/central-cu-advancement"
      },
      "sameAs": [
        "https://projects.propublica.org/nonprofits/organizations/846049811",
        "https://en.wikipedia.org/wiki/University_of_Colorado",
        "https://www.cufund.org"
      ],
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["h1", ".field--name-body p.intro", "meta[name='description']"]
      }
    }
    </script>

  </head>

  <body{{ attributes.addClass(body_classes) }}>

    <a href="#main" class="visually-hidden focusable">
      {{ 'Skip to main content'|t }}
    </a>

    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-KBWW4MVB"
        height="0"
        width="0"
        style="display:none;visibility:hidden">
      </iframe>
    </noscript>

    {{ page_top }}
    {{ page }}
    {{ page_bottom }}

    <js-bottom-placeholder token="{{ placeholder_token|raw }}">

  </body>
</html>