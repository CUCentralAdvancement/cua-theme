<!DOCTYPE html>
<html{{ html_attributes }}>
<head>

  {# ── Performance hints ──────────────────────────────────────────── #}
  <link rel="preconnect" href="https://www.googletagmanager.com">
  <link rel="dns-prefetch" href="https://www.googletagmanager.com">

  {# ── Font preloads ───────────────────────────────────────────────── #}
  <link rel="preload" href="/themes/contrib/cua_theme/fonts/roboto-condensed-v31-latin-regular.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/themes/contrib/cua_theme/fonts/roboto-v51-latin-regular.woff2" as="font" type="font/woff2" crossorigin>
  
  {# ── Font preloads (The Bridge-Prevention Protection Act) ──────────────── #}
  <link rel="preload" href="/themes/contrib/cua_theme/dist/fontawesome/webfonts/fa-regular-400.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/themes/contrib/cua_theme/dist/fontawesome/webfonts/fa-solid-900.woff2" as="font" type="font/woff2" crossorigin>
  
  {# ── GTM — must be as high in <head> as possible ────────────────── #}
  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-KBWW4MVB');</script>

  {# ── Drupal head, CSS, JS placeholders — sequential, never nested ── #}
  <head-placeholder token="{{ placeholder_token|raw }}">
  <title>{{ head_title|safe_join(' | ') }}</title>
  <css-placeholder token="{{ placeholder_token|raw }}">
  <js-placeholder token="{{ placeholder_token|raw }}">

