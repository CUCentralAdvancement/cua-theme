{#
/**
 * @file
 * FAQ node template.
 *
 * In a listing/teaser context — e.g. the /faq/[category] taxonomy term page —
 * render the question as a heading with the answer beneath it. The base node
 * template's `label` variable comes through empty in that render path, so the
 * question is read from `node.label` directly (same fix used for articles).
 *
 * On the full FAQ page (page = true) the page title handles the heading and
 * Layout Builder renders the body, so the question heading is skipped here.
 */
#}
{%- set classes = [
  'node',
  'node--type-' ~ node.bundle|clean_class,
  view_mode ? 'node--view-mode-' ~ view_mode|clean_class,
] -%}

{#-- JSON-LD: single-question page = FAQPage (switched from QAPage 2026-07:
     Google reads QAPage as forum-style community Q&A; FAQPage is the type
     for site-authored FAQs, and is what AI answer engines extract from).
     Question text is the node title; acceptedAnswer is the body, stripped
     to plain text — it must stay in parity with the visible answer. Only on
     the node's own page — never in listings, where the /faq page-level
     graph covers the collection. publisher references the NGO entity
     declared in html.html.twig's @graph. A BreadcrumbList rides along for
     navigational context. --#}
{% if view_mode == 'full' and page %}
{%- set _answer = node.field_answer.value is defined ? node.field_answer.value|render|striptags|trim : '' -%}
{%- set _question = node.label|render|striptags|trim -%}
{%- set _url = url('<current>')|render -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": {{ (_url ~ '#faqpage')|json_encode|raw }},
  "url": {{ _url|json_encode|raw }},
  "mainEntity": [{
    "@type": "Question",
    "name": {{ _question|json_encode|raw }},
    "acceptedAnswer": {
      "@type": "Answer",
      "text": {{ _answer|json_encode|raw }},
      "url": {{ _url|json_encode|raw }}
    }
  }],
  "publisher": { "@id": "https://www.giving.cu.edu/#foundation" }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": {{ url('<front>')|render|json_encode|raw }} },
    { "@type": "ListItem", "position": 2, "name": "FAQ", "item": {{ (url('<front>')|render ~ 'faq')|json_encode|raw }} },
    { "@type": "ListItem", "position": 3, "name": {{ _question|json_encode|raw }}, "item": {{ _url|json_encode|raw }} }
  ]
}
</script>
{% endif %}

<article{{ attributes.addClass(classes) }}>
  <header>
    {{ title_prefix }}
    {% if not page %}
      <h3 class="faq-question mt-4 mb-2">{{ node.label }}</h3>
    {% endif %}
    {{ title_suffix }}
  </header>

  <div class="node__content">
    {{ content }}
  </div>
</article>
