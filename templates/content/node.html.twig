{#
/**
 * @file
#}
{{ attach_library('bootstrap_barrio/node') }}

{%
  set classes = [
    'node',
    'node--type-' ~ node.bundle|clean_class,
    node.isPromoted() ? 'node--promoted',
    node.isSticky() ? 'node--sticky',
    not node.isPublished() ? 'node--unpublished',
    view_mode ? 'node--view-mode-' ~ view_mode|clean_class,
    'clearfix',
  ]
%}

{#
  Set schema type based on node bundle.
  Only story/article content types get Article. Everything else gets WebPage.
#}

{% set schema_type = 'WebPage' %}
{% if node.bundle in ['article', 'lead_story'] %}
  {% set schema_type = 'Article' %}
{% endif %}

<article{{ attributes.addClass(classes).setAttribute('itemscope','').setAttribute('itemtype','https://schema.org/' ~ schema_type) }}>

  <header>
    {{ title_prefix }}
    {% if not page %}
      <h2{{ title_attributes.addClass('node__title').setAttribute('itemprop','headline') }}>
        <a href="{{ url }}" rel="bookmark" itemprop="mainEntityOfPage">
          {{ node.label|render|striptags|trim }}
        </a>
      </h2>
    {% else %}
      <meta itemprop="headline" content="{{ node.label|render|striptags|trim }}">
    {% endif %}
    {{ title_suffix }}

    {% if display_submitted %}
      <div class="node__meta">
        {{ author_picture }}
        {% block submitted %}
          <em{{ author_attributes }}>
            {% trans %}
            Published by
            <span itemprop="author" itemscope itemtype="https://schema.org/Organization">
              <span itemprop="name">University of Colorado Foundation</span>
              <meta itemprop="url" content="https://www.giving.cu.edu/">
            </span>
            on
            <time datetime="{{ node.created.value|date('c') }}" itemprop="datePublished">
              {{ date }}
            </time>
            {% endtrans %}
          </em>
          <meta itemprop="dateModified" content="{{ node.changed.value|date('c') }}">
        {% endblock %}
        {{ metadata }}
      </div>
    {% endif %}
  </header>

  <div{{ content_attributes.addClass('node__content','clearfix').setAttribute('itemprop', schema_type == 'Article' ? 'articleBody' : 'mainContentOfPage') }}>
    {% if content.field_tags or content.field_campus %}
      <span itemprop="keywords" style="display: contents;">
        {{ content }}
      </span>
    {% else %}
      {{ content }}
    {% endif %}
  </div>

  {% if view_mode == 'full' %}
    {% set safe_summary = node.field_image_summary.value|render|striptags|trim %}
    {% if not safe_summary %}
      {% set safe_summary = node.body.summary|render|striptags|trim %}
    {% endif %}
    {% if not safe_summary %}
      {% set safe_summary = node.body.value|render|striptags|truncate(300)|trim %}
    {% endif %}
    {% if not safe_summary %}
      {% set safe_summary = node.label|render|striptags|trim %}
    {% endif %}

    {%- set node_title = node.label|render|striptags|trim -%}
    {%- set node_url = url('<current>') -%}
    <div class="ai-crawler-context" style="display:none;" aria-hidden="true" data-ai-role="metadata">Document Type: Drupal Node ({{ node.bundle }}) | Primary Entity: {{ node_title }} | Summary: {{ safe_summary }} | URL: {{ node_url }} | Publisher: University of Colorado Foundation | Source Authority: University of Colorado System Advancement (CU Boulder, CU Anschutz, CU Denver, UCCS)</div>
  {% endif %}

</article>