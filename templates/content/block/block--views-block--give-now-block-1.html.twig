{#-
  =============================================================================
  COMPONENT: Give Now Grid (Multi-Campus)
  STABILITY: Production-Stable
  SCHEMA STRATEGY (2026-06):
    - Single JSON-LD <script> block replaces all Microdata attributes
    - ItemList built in a pre-loop — view owns all 4 items simultaneously
      so ItemList is semantically valid (unlike isolated Layout Builder blocks)
    - DonateAction per campus with CollegeOrUniversity recipient
      (TradeAction subtype — no expectsAcceptanceOf requirement, unlike
      ReadAction/ConsumeAction)
    - campus_names / campus_urls maps provide KG-aligned entity names and
      canonical URLs for Knowledge Graph linkage
    - Absolute image URLs via site_base (image_style returns relative paths;
      base_url and app.request are unavailable in this block template context)
    - Link URIs resolved to absolute: internal:/ and entity: schemes converted,
      '#' fallback omitted from schema rather than emitted as invalid URL
    - numberOfItems counts built items, not raw view rows
    - All itemscope / itemtype / itemprop attributes removed from HTML
    - width/height on <img> set to match give_now image style (360x240)
      to prevent CLS layout shifts per Lighthouse / Core Web Vitals
  =============================================================================
-#}

{{- attach_library('cua_theme/call-to-action') -}}

{%- if user.hasPermission('administer site configuration') -%}
  <nav class="admin-interface d-flex justify-content-center gap-2 m-2" aria-label="Admin Actions">
    <a href="/give-now/view-all" class="btn btn-sm btn-admin-app">{{ 'Manage Schedules & Content'|t }}</a>
    <a href="/internal-documentation-giving-day-content-swap-process" class="btn btn-sm btn-admin-app">{{ 'Launch Guide'|t }}</a>
  </nav>
{%- endif -%}

{%- set section_title = 'Ways to Give to the University of Colorado Boulder, University of Colorado Colorado Springs, University of Colorado Denver, and University of Colorado Anschutz Medical Campus'|t -%}

{%- set site_base = 'https://www.giving.cu.edu' -%}

{%- set campus_names = {
  'CU Boulder':  'University of Colorado Boulder',
  'UCCS':        'University of Colorado Colorado Springs',
  'CU Denver':   'University of Colorado Denver',
  'CU Anschutz': 'University of Colorado Anschutz Medical Campus',
} -%}

{%- set campus_urls = {
  'CU Boulder':  'https://www.colorado.edu',
  'UCCS':        'https://www.uccs.edu',
  'CU Denver':   'https://www.ucdenver.edu',
  'CU Anschutz': 'https://www.cuanschutz.edu',
} -%}

{%- if content['#view'].result is not empty -%}
  {%- set view = content['#view'] -%}

  {# ===========================================================================
     JSON-LD PRE-LOOP
     Build the full ItemList before HTML renders.
     =========================================================================== #}
  {%- set _jsonld_items = [] -%}

  {%- for row in view.result -%}
    {%- if row._entity is not empty -%}
      {%- set node        = row._entity -%}
      {%- set label       = node.label|trim -%}
      {%- set _campus     = campus_names[label] ?: 'University of Colorado ' ~ label -%}
      {%- set _campus_url = campus_urls[label] ?: '' -%}
      {%- set _desc       = node.body.value|striptags|trim -%}

      {# Resolve link URI to an absolute URL for schema.
         field_link.uri may be https://…, internal:/path, or entity:node/NID. #}
      {%- set _link_raw = node.field_link.uri -%}
      {%- if _link_raw starts with 'http' -%}
        {%- set _link = _link_raw -%}
      {%- elseif _link_raw starts with 'internal:' -%}
        {%- set _link = site_base ~ _link_raw|replace({'internal:': ''}) -%}
      {%- elseif _link_raw starts with 'entity:' -%}
        {%- set _link = site_base ~ '/' ~ _link_raw|replace({'entity:': ''}) -%}
      {%- else -%}
        {%- set _link = null -%}
      {%- endif -%}

      {%- set _action = {
        '@type':        'DonateAction',
        'name':         'Give to ' ~ _campus,
        'actionStatus': 'https://schema.org/PotentialActionStatus',
        'recipient': {
          '@type': 'CollegeOrUniversity',
          'name':  _campus,
          'url':   _campus_url,
        },
      } -%}

      {%- if _link -%}
        {%- set _action = _action|merge({'url': _link}) -%}
      {%- endif -%}

      {%- if _desc is not empty -%}
        {%- set _action = _action|merge({'description': _desc}) -%}
      {%- endif -%}

      {%- if node.field_image.entity -%}
        {%- set _image_url_raw = node.field_image.entity.fileuri|image_style('give_now') -%}
        {%- set _image_url = (_image_url_raw starts with 'http') ? _image_url_raw : (site_base ~ '/' ~ _image_url_raw|trim('/')) -%}
        {%- set _action = _action|merge({
          'image': {
            '@type':   'ImageObject',
            'url':     _image_url,
            'width':   360,
            'height':  240,
            'caption': node.field_image.alt|default(label)|trim,
          },
        }) -%}
      {%- endif -%}

      {%- set _jsonld_items = _jsonld_items|merge([{
        '@type':    'ListItem',
        'position': _jsonld_items|length + 1,
        'item':     _action,
      }]) -%}

    {%- endif -%}
  {%- endfor -%}

  {%- if _jsonld_items|length > 0 -%}
    {%- set _jsonld = {
      '@context':        'https://schema.org',
      '@type':           'ItemList',
      'name':            section_title,
      'itemListOrder':   'https://schema.org/ItemListUnordered',
      'numberOfItems':   _jsonld_items|length,
      'itemListElement': _jsonld_items,
    } -%}

    <script type="application/ld+json">
    {{ _jsonld|json_encode|raw }}
    </script>
  {%- endif -%}

  {# ===========================================================================
     HTML — layout unchanged, Microdata attributes removed
     width/height added to <img> to eliminate CLS layout shifts
     Anchor tag kept on a single line — do not split the <a from its
     attributes; a prior paste dropped the opening tag and printed raw
     attributes to screen
     =========================================================================== #}
  <section
      class="container-fluid` px-3"
      role="region"
      aria-labelledby="give-now-section-title">

    <h2 id="give-now-section-title" class="visually-hidden">
      {{- section_title -}}
    </h2>

    <ul class="row list-unstyled m-0">
      {%- for row in view.result -%}
        {%- if row._entity is not empty -%}
          {%- set node       = row._entity -%}
          {%- set heading_id = 'give-now-item-' ~ node.id ~ '-title' -%}
          {%- set body_id    = 'give-now-item-' ~ node.id ~ '-body' -%}
          {%- set link       = node.field_link.uri ?: '#' -%}
          {%- set label      = node.label|trim -%}

          <li class="col-12 col-sm-6 col-lg-3 give-now-wrapper mb-4">

            {%- apply spaceless -%}

            <a href="{{ link }}" id="give-now-item-{{ node.id }}" class="give-now-item d-flex flex-column text-decoration-none h-100 story-link" aria-describedby="{{ body_id }}">

              <div class="m-2 h-100 shadow {{ node.field_color_background.value ?: 'cu-bg-white' }}" role="presentation">

                <figure class="position-relative mb-0" role="presentation">

                  {%- if node.field_flag.value == 'flag_on' -%}
                    {%- set flag_classes = [
                      'flag',
                      'py-2',
                      node.field_flag_background.value ?: null,
                    ]|filter(v => v) -%}
                    <div class="position-absolute start-0 top-0 z-1">
                      <div class="{{ flag_classes|join(' ')|trim }}"
                           style="width:max-content;display:flex;align-items:center;padding:5px 10px;white-space:nowrap;">
                        {%- if node.field_icon.value -%}
                          <i class="{{ node.field_icon.value }} {{ node.field_icon_size.value }} px-1"
                             style="color:{{ node.field_icon_color.value }}"
                             aria-hidden="true"></i>
                        {%- endif -%}
                        {%- if node.field_flag_title.value -%}
                          <span class="flag-title">{{- node.field_flag_title.value|trim -}}</span>
                        {%- endif -%}
                      </div>
                    </div>
                  {%- endif -%}

                  {%- if node.field_image.entity -%}
                    {%- set image_url = node.field_image.entity.fileuri|image_style('give_now') -%}
                    <img
                        src="{{ image_url }}"
                        alt="{{ node.field_image.alt|default(label)|trim }}"
                        width="360"
                        height="240"
                        loading="{{ loop.first ? 'eager' : 'lazy' }}"
                        fetchpriority="{{ loop.first ? 'high' : 'auto' }}"
                        class="card-header mb-2"/>
                  {%- endif -%}

                </figure>

                <div class="give-now-content px-3 pt-2">
                  <h3 id="{{ heading_id }}" class="give-now-title fs-3 fw-bold">
                    {{- label -}}
                    {%- if node.field_subtitle.value -%}
                      <span class="fs-4 fw-normal d-block">
                        {{- node.field_subtitle.value|trim -}}
                      </span>
                    {%- endif -%}
                  </h3>

                  <div id="{{ body_id }}" class="give-now-body mb-2 mx-1 pt-2">
                    {{- node.body.value|raw -}}
                  </div>

                  {%- if node.field_link.title is not empty -%}
                    <div class="card-footer card-story d-flex p-0 mb-5 mx-1">
                      <span class="card-link btn outline-btn-cu-bg-black text-decoration-none p-2 mt-3"
                            aria-hidden="true">
                        {{- node.field_link.title|trim -}}
                      </span>
                    </div>
                  {%- endif -%}

                </div>{#- /.give-now-content -#}
              </div>{#- /.shadow -#}
            </a>

            {%- endapply -%}
          </li>

        {%- endif -%}
      {%- endfor -%}
    </ul>

  </section>

{%- endif -%}