{#
  =============================================================================
  COMPONENT: Give Now - Institutional Multi-Campus Grid
  STABILITY: Production-Stable / Architecture: Sinn 556 iRS Equivalent (Minimal/Tough)
  COMPLIANCE: Section 508 / WCAG 2.2 Level AA / ADA Title II Ready
  VERSION: 2.2.0 — Defensive null checks ported from lead-story. Sort-page safe.
  =============================================================================
  CHANGE LOG:
  v2.2.0 — Added defensive null checks on field_image.entity, field_icon,
            field_flag_title, and field_link.title to prevent silent render
            failures on sort page and other non-view contexts. Removed stray
            backtick at EOF. title_prefix/title_suffix confirmed present.
            Fixed aria operator precedence bug on 'Funds for' translation.
            Switched aria-label on <ul> to aria-labelledby for WCAG 1.3.1.
  =============================================================================

  OVERVIEW
  --------
  This template renders a responsive 4-column grid (1→2→4 at sm/lg breakpoints)
  of "Give Now" donation cards for the University of Colorado system, spanning
  all four campuses: Boulder, UCCS, CU Denver, and Anschutz Medical.

  Each card is backed by a Drupal content type with machine name "gi" (Give Now
  Item). Cards are sourced through a Drupal Views result set and iterated via
  view.result. The template is consumed by a custom block plugin.

  WHERE THIS TEMPLATE LIVES IN THE THEME
  ---------------------------------------
  Expected path (relative to theme root):
    templates/block/block--give-now.html.twig
  OR if used as a views-block override:
    templates/views/views-view--give-now.html.twig
  Check your theme's template_preprocess hooks to confirm the suggestion order.

  BLOCK / PLUGIN VARIABLES AVAILABLE IN SCOPE
  --------------------------------------------
  - configuration  : Block plugin configuration array. Used here for CSS class
                     generation via configuration.provider (the plugin provider
                     machine name, e.g. "block_content").
  - plugin_id      : Machine name of the block plugin (e.g. "views_block:give_now-block_1").
                     Used for CSS class generation.
  - id             : Unique instance ID of this block placement. May be null in
                     non-block contexts (sort page, layout builder preview).
                     Always guard with `id ? ... : null` as done below.
  - utility_classes: Array of extra CSS classes injected by Layout Builder or
                     other placement systems. Merged into givenow_classes.
  - content        : The standard Drupal block content render array.
                     content['#view'] holds the underlying Views object when
                     this block wraps a View.
  - user           : The current Drupal user object. Used for permission checks.
  - title_prefix / title_suffix : Drupal-injected wrappers for contextual links
                     (e.g., the "Configure block" pencil icon in admin mode).
                     These MUST remain in the template even if visually unused.
#}

{#
  LIBRARY ATTACHMENT
  ------------------
  Attaches the 'call-to-action' JS/CSS library defined in cua_theme.libraries.yml.
  This library is expected to provide hover effects, click-tracking analytics
  hooks, and any JS behavior for the .story-link anchor pattern.
  If this library is missing you will see a Drupal warning in the log but no
  hard failure — the cards will still render, just unstyled/unenhanced.
#}
{{ attach_library('cua_theme/call-to-action') }}

{# 
  DEV NOTE: ADMIN CONTROLS
  We are checking for a specific Drupal permission string here. 
  By keeping these links hardcoded in the template rather than using Drupal's menu system, 
  we avoid menu caching complexities for authenticated vs. anonymous users.
  The `d-flex justify-content-center m-2` utilizes Bootstrap 5 utility classes.
#}
{# ===========================
   ADMIN CONTROLS (unchanged)
   =========================== #}
{% if user.hasPermission('administer site configuration') %}
    <div class="admin-interface d-flex justify-content-center m-2"
         role="group"
         aria-label="Administrative Actions">
        <a href="/admin/content/scheduled" class="btn btn-secondary mx-2">{{ 'Scheduled Give Now'|t }}</a>
        <a href="/admin/content?title=&type=gi&status=All" class="btn btn-secondary mx-2">{{ 'Edit Give Now Blocks'|t }}</a>
        <a href="/node/add/gi" class="btn btn-secondary mx-2">{{ 'Add new Give Now'|t }}</a>
        <a href="/internal-documentation-giving-day-content-swap-process" class="btn btn-secondary mx-2">{{ 'Giving Day Launch Guide'|t }}</a>
    </div>
{% endif %}

{# 
  DEV NOTE: CONTEXTUAL LINKS
  `title_prefix` and `title_suffix` are required by Drupal's Render API.
  If these are removed, the quick-edit "pencil" icon will not appear for content editors when hovering over this block.
#}
{{ title_prefix }}
{{ title_suffix }}

{# 
  DEV NOTE: VIEW WRAPPER GUARD
  Because this template might be suggested by a block preprocess hook that doesn't strictly contain a view 
  (e.g., Layout Builder preview screens or block configuration pages), checking if `content['#view']` exists 
  prevents WSOD (White Screen of Death) fatal errors.
#}
{# ===========================
   VIEW WRAPPER
   =========================== #}
{% if content['#view'] is not empty %}
    {% set view = content['#view'] %}

    {# 
      DEV NOTE: EMPTY STATE CHECK
      Ensures we don't render an empty `<section>` tag if the View returns no results. 
      This is crucial for SEO and accessibility (avoiding empty landmark regions).
    #}
    {% if view.result is not empty %}

        {# 
          DEV NOTE: ACCESSIBILITY & SCHEMA
          The `role="region"` and `aria-labelledby` tie this entire section to a hidden <h2>.
          This gives screen reader users necessary context ("Ways to Give...") without cluttering the visual UI.
          The `itemscope` and `itemtype` initiate Schema.org structured data for rich search results.
        #}
        <section class="container-fluid bg-gray-20 px-2 pt-1 pb-5"
                 role="region"
                 aria-labelledby="give-now-section-title"
                 itemscope
                 itemtype="https://schema.org/ItemList">

            <meta itemprop="name" content="Ways to Give" />

            <h2 id="give-now-section-title"
                class="visually-hidden">
                {{ 'Ways to Give to CU Boulder, UCCS, CU Denver, and Anschutz'|t }}
            </h2>

            <ul class="row list-unstyled"
                itemprop="itemListElement">

                {# 
                  DEV NOTE: LOOPING THE VIEW
                  `view.result` contains the raw result rows. `row._entity` is the fully loaded Drupal Node object.
                  We extract `row._entity` so we can access entity fields directly (e.g., node.field_name.value)
                  instead of relying on Views field rendering (which can be heavy and introduces unwanted wrapper markup).
                #}
                {% for row in view.result %}
                    {% if row._entity is not empty %}

                        {% set node       = row._entity %}
                        
                        {# 
                          DEV NOTE: DYNAMIC ID GENERATION
                          Using `node.id` guarantees uniqueness across the DOM. 
                          These IDs are critical because they are referenced by `aria-describedby` and `aria-labelledby` below, 
                          creating an accessible programmatic relationship between the card's link and its text.
                        #}
                        {% set heading_id = 'give-now-item-' ~ node.id ~ '-title' %}
                        {% set body_id    = 'give-now-item-' ~ node.id ~ '-body' %}
                        
                        {# Defensive fallback for the URL: defaults to '#' if the field is empty #}
                        {% set link       = node.field_link.uri ?: '#' %}

                        <li class="col-12 col-sm-6 col-lg-3 give-now-wrapper mb-4"
                            itemscope
                            itemtype="https://schema.org/Action"
                            itemprop="itemListElement">

                            <meta itemprop="position" content="{{ loop.index }}" />

                            {# 
                              DEV NOTE: BLOCK-LEVEL LINK PATTERN
                              Wrapping the entire card contents in a single `<a>` tag is an modern UI pattern 
                              that increases the tap target size for mobile users. 
                              The class `.story-link` (attached via the library at the top) likely handles focus/hover states.
                            #}
                            <a href="{{ link }}"
                               id="give-now-item-{{ node.id }}"
                               class="give-now-item d-flex flex-column text-decoration-none h-100 story-link"
                               aria-describedby="{{ body_id }}"
                               itemprop="url">

                                <article class="m-2 h-100 {{ node.field_shadow.value == 'shadow' ? 'shadow' : '' }} {{ node.field_color_background.value ?: '' }}"
                                         role="group"
                                         aria-labelledby="{{ heading_id }}"
                                         itemscope
                                         itemtype="https://schema.org/CreativeWork">

                                    {# ===========================
                                       FLAG + IMAGE REGION
                                       =========================== #}
                                    <figure class="position-relative" role="presentation">

                                        {# 
                                          DEV NOTE: FLAG RENDER LOGIC
                                          The flag acts as a contextual badge (e.g., "Urgent", "New Fund").
                                          Notice the inline styles here; while generally avoided, they are used here 
                                          to enforce strict dimensional constraints regardless of the surrounding theme CSS.
                                        #}
                                        {% if node.field_flag.value == 'flag_on' %}
                                            <div class="position-absolute start-0">
                                                <div class="flag py-2 {{ node.field_flag_background.value ?: '' }}"
                                                     style="width:max-content;display:flex;align-items:center;padding:5px 10px;white-space:nowrap;">
                                                    {% if node.field_icon.value %}
                                                        <i class="{{ node.field_icon.value }} {{ node.field_icon_size.value }} px-1"
                                                           style="color:{{ node.field_icon_color.value }}"
                                                           aria-hidden="true"></i>
                                                    {% endif %}
                                                    {% if node.field_flag_title.value %}
                                                        <span class="flag-title">{{ node.field_flag_title.value }}</span>
                                                    {% endif %}
                                                </div>
                                            </div>
                                        {% endif %}

                                        {# 
                                          DEV NOTE: IMAGE RENDERING
                                          Checking `node.field_image.entity` is a vital defensive check. 
                                          If the node has an image field, but no image is actually uploaded, 
                                          trying to access `entity.fileuri` will throw a fatal error.
                                          We also pipe the URI through `image_style('lead_story')` to let Drupal handle responsive cropping/sizing.
                                        #}
                                        {% if node.field_image.entity %}
                                            {% set image_url = node.field_image.entity.fileuri | image_style('lead_story') %}
                                            {% set alt_text  = node.field_image.alt|trim is not empty ? node.field_image.alt : 'Image for ' ~ node.label %}
                                            <img src="{{ image_url }}"
                                                 alt="{{ alt_text }}"
                                                 loading="lazy"
                                                 class="img-fluid card-header mb-2"
                                                 itemprop="image">
                                        {% endif %}
                                    </figure>

                                    {# ===========================
                                       CONTENT REGION
                                       =========================== #}
                                    <div class="give-now-content px-3 pt-2">

                                        {# 
                                          DEV NOTE: ACCESSIBLE TYPOGRAPHY
                                          This H3 is the anchor point for the `aria-labelledby` on the parent `<article>`.
                                          If a subtitle exists, it's rendered visually as a block, but kept within the <h3> 
                                          so screen readers announce both the Title and Subtitle together cohesively.
                                        #}
                                        <h3 id="{{ heading_id }}"
                                            class="give-now-title fs-3 fw-bold"
                                            itemprop="name">
                                            {{ node.label }}
                                            {% if node.field_subtitle.value %}
                                                <span class="fs-4 fw-normal d-block"
                                                      itemprop="alternateName">
                                                    {{ node.field_subtitle.value }}
                                                </span>
                                            {% endif %}
                                        </h3>

                                        {# 
                                          DEV NOTE: BODY RENDERING
                                          The `|raw` filter is used here because WYSIWYG body fields contain HTML tags (like <p>, <strong>, etc.).
                                          Without `|raw`, Twig will auto-escape the HTML and output literal `<p>` strings to the browser.
                                          This is safe because content entered via the Drupal admin UI goes through XSS filtering on save.
                                        #}
                                        <div id="{{ body_id }}"
                                             class="give-now-body mb-2 mx-1 pt-2"
                                             itemprop="description">
                                            {{ node.body.value|raw }}
                                        </div>

                                        {# 
                                          DEV NOTE: THE "FAKE" BUTTON
                                          Because the entire card is wrapped in an `<a>` tag, adding a `<button>` or another `<a>` here
                                          would create invalid HTML (nested interactive elements). 
                                          Instead, we use a `<span>` styled to look like a button. 
                                          `aria-hidden="true"` prevents screen readers from redundantly announcing "Read More" 
                                          since they already read the card's main link context.
                                        #}
                                        {% if node.field_link.title is not empty %}
                                        <div class="card-footer card-story d-flex p-0 mb-5 mx-1">
                                            <span class="card-link btn outline-btn-cu-bg-black text-decoration-none p-2 mt-3" aria-hidden="true">
                                                {{ node.field_link.title }}
                                            </span>
                                        </div>
                                    {% endif %}

                                    </div>

                                </article>
                            </a>
                        </li>

                    {% endif %}
                {% endfor %}
            </ul>
        </section>
    {% endif %}
{% endif %}`