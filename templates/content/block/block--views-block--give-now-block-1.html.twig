{#
  =============================================================================
  COMPONENT: Give Now - Institutional Multi-Campus Grid
  STABILITY: Production-Stable | Architecture: Minimal/Tough (Sinn 556 ethos)
  COMPLIANCE: Section 508 / WCAG 2.2 Level AA / ADA Title II Ready
  =============================================================================
  CHANGELOG:
  v2.3.0 — Switched per-card edit links to use user.hasPermission() and 
           node.getOwnerId(). (node.access() throws Twig\Sandbox\SecurityError).
  v2.2.0 — Added null checks (field_image.entity, field_icon, etc.) to prevent 
           silent crashes. Fixed WCAG 1.3.1 aria bug.
  =============================================================================
  CONTEXT & VARIABLES:
  - Sourced via Drupal Views result set (content type: "gi").
  - Scope: `configuration`, `plugin_id`, `id`, `user`, `title_prefix`/`suffix`.
  - Expects 'cua_theme/call-to-action' library for .story-link interactions.
#}
{{ attach_library('cua_theme/call-to-action') }}

{# 
  ADMIN CONTROLS & CONTEXTUAL LINKS
  - Hardcoded links check permissions directly to bypass menu caching 
    complexities for authenticated vs. anonymous users.
  - title_prefix/suffix are required by Drupal Render API; removing them 
    breaks the quick-edit "pencil" icon for content editors.
#}
{% if user.hasPermission('administer site configuration') %}
    <div class="admin-interface d-flex justify-content-center m-2"
         role="group"
         aria-label="Administrative Actions">
        <a href="/admin/content/scheduled" class="btn btn-secondary mx-2">{{ 'View Schedule'|t }}</a>
        <a href="/internal-documentation-giving-day-content-swap-process" class="btn btn-secondary mx-2">{{ 'Giving Day Launch Guide'|t }}</a>
    </div>
{% endif %}

{{ title_prefix }}
{{ title_suffix }}

{# 
  VIEW WRAPPER & EMPTY STATE
  1. `content['#view']` check prevents WSOD in non-view contexts (Layout Builder).
  2. `view.result` check prevents rendering empty landmark regions (SEO/A11y).
#}
{% if content['#view'] is not empty %}
    {% set view = content['#view'] %}

    {% if view.result is not empty %}

        {# 
          ACCESSIBILITY & SCHEMA
          Ties section to a visually hidden <h2> for screen readers without UI clutter.
          Initializes Schema.org ItemList for rich search results.
        #}
        <section class="container-fluid bg-gray-20 px-2 pt-1 pb-5"
                 role="region"
                 aria-labelledby="give-now-section-title"
                 itemscope
                 itemtype="https://schema.org/ItemList">

            <meta itemprop="name" content="Ways to Give" />

            <h2 id="give-now-section-title"
                class="visually-hidden">
                {{ 'Ways to Give to CU Boulder, UCCS, CU Denver, and Anschutz'|t }}
            </h2>

            <ul class="row list-unstyled"
                itemprop="itemListElement">

                {# 
                  GRID LOOP & ACCESSIBILITY IDs
                  Extracts raw `row._entity` to access fields directly, bypassing heavy Views wrappers.
                  `node.id` guarantees unique DOM IDs for aria-describedby/labelledby relationships.
                #}
                {% for row in view.result %}
                    {% if row._entity is not empty %}

                        {% set node       = row._entity %}
                        
                        {% set heading_id = 'give-now-item-' ~ node.id ~ '-title' %}
                        {% set body_id    = 'give-now-item-' ~ node.id ~ '-body' %}
                        
                        {# Defensive fallback for the URL: defaults to '#' if the field is empty #}
                        {% set link       = node.field_link.uri ?: '#' %}

                        <li class="col-12 col-sm-6 col-lg-3 give-now-wrapper mb-4"
                            itemscope
                            itemtype="https://schema.org/Action"
                            itemprop="itemListElement">

                            <meta itemprop="position" content="{{ loop.index }}" />

                            {# 
                              CARD ANCHOR
                              Wraps the card in a single <a> for a larger mobile tap target.
                              Relies on .story-link (from attached library) for focus/hover states.
                            #}
                            <a href="{{ link }}"
                               id="give-now-item-{{ node.id }}"
                               class="give-now-item d-flex flex-column text-decoration-none h-100 story-link"
                               aria-describedby="{{ body_id }}"
                               itemprop="url">

                                <article class="m-2 h-100 {{ node.field_shadow.value == 'shadow' ? 'shadow' : '' }} {{ node.field_color_background.value ?: '' }}"
                                         role="group"
                                         aria-labelledby="{{ heading_id }}"
                                         itemscope
                                         itemtype="https://schema.org/CreativeWork">

                                    <figure class="position-relative" role="presentation">

                                        {# 
                                          FLAG
                                          Inline styles are used here intentionally to enforce strict dimensional 
                                          constraints regardless of surrounding theme CSS changes.
                                        #}
                                        {% if node.field_flag.value == 'flag_on' %}
                                            <div class="position-absolute start-0">
                                                <div class="flag py-2 {{ node.field_flag_background.value ?: '' }}"
                                                     style="width:max-content;display:flex;align-items:center;padding:5px 10px;white-space:nowrap;">
                                                    {% if node.field_icon.value %}
                                                        <i class="{{ node.field_icon.value }} {{ node.field_icon_size.value }} px-1"
                                                           style="color:{{ node.field_icon_color.value }}"
                                                           aria-hidden="true"></i>
                                                    {% endif %}
                                                    {% if node.field_flag_title.value %}
                                                        <span class="flag-title">{{ node.field_flag_title.value }}</span>
                                                    {% endif %}
                                                </div>
                                            </div>
                                        {% endif %}

                                        {#
                                          ADMIN DEBUG BADGES
                                          Visible only to 'administer site configuration'.
                                          1. Publish State: Uses sandbox-safe `node.isPublished()`.
                                          2. Sort Order: Displays Views sort criteria (weight + alpha tiebreaker). 
                                             Null-coalescing (`??`) prevents fatal errors on empty fields.
                                        #}
                                        {% if user.hasPermission('administer site configuration') %}
                                            <div class="d-flex justify-content-center gap-2 my-2">
                                                <div class="badge {{ node.isPublished() ? 'bg-success' : 'bg-danger' }} text-white">
                                                    {{ node.isPublished() ? 'Published'|t : 'Unpublished'|t }}
                                               </div>
                                                <div class="badge bg-dark text-white">
                                                    {{ ('Position:'|t) ~ ' ' ~ (node.field_sort_weight.0.value ?? '') ~ '' ~ (''|t) ~ '' ~ (node.field_alpha_order.0.value ?? '') }}
                                                </div> 
                                            </div>
                                        {% endif %}

                                        {# 
                                          IMAGE
                                          Checks `node.field_image.entity` before accessing `fileuri` to prevent 
                                          fatal errors on empty uploads. Handled via 'lead_story' image style.
                                        #}
                                        {% if node.field_image.entity %}
                                            {% set image_url = node.field_image.entity.fileuri | image_style('lead_story') %}
                                            {% set alt_text  = node.field_image.alt|trim is not empty ? node.field_image.alt : 'Image for ' ~ node.label %}
                                            <img src="{{ image_url }}"
                                                 alt="{{ alt_text }}"
                                                 loading="lazy"
                                                 class="img-fluid card-header mb-2"
                                                 itemprop="image">
                                        {% endif %}
                                    </figure>

                                    <div class="give-now-content px-3 pt-2">

                                        {# 
                                          TYPOGRAPHY & BODY
                                          - Subtitle is kept inside the <h3> so screen readers announce both together.
                                          - `|raw` is safe here (admin XSS filtered) and prevents Twig from 
                                            auto-escaping WYSIWYG HTML tags.
                                        #}
                                        <h3 id="{{ heading_id }}"
                                            class="give-now-title fs-3 fw-bold"
                                            itemprop="name">
                                            {{ node.label }}
                                            {% if node.field_subtitle.value %}
                                                <span class="fs-4 fw-normal d-block"
                                                      itemprop="alternateName">
                                                    {{ node.field_subtitle.value }}
                                                </span>
                                            {% endif %}
                                        </h3>

                                        <div id="{{ body_id }}"
                                             class="give-now-body mb-2 mx-1 pt-2"
                                             itemprop="description">
                                            {{ node.body.value|raw }}
                                        </div>

                                        {# 
                                          "FAKE" BUTTON
                                          Since the card is already wrapped in an <a> tag, we use a styled <span> here 
                                          to avoid invalid HTML (nested interactives). aria-hidden prevents redundancy.
                                        #}
                                        {% if node.field_link.title is not empty %}
                                            <div class="card-footer card-story d-flex p-0 mb-5 mx-1">
                                                <span class="card-link btn outline-btn-cu-bg-black text-decoration-none p-2 mt-3" aria-hidden="true">
                                                    {{ node.field_link.title }}
                                                </span>
                                            </div>
                                        {% endif %}

                                    </div>

                                </article>
                            </a>

                               {% if user.hasPermission('edit any gi content') or
                                  (user.hasPermission('edit own gi content') and node.getOwnerId() == user.id) %}
                                <div class="give-now-edit-link d-flex justify-content-center my-3">
                                    <a href="{{ path('entity.node.edit_form', {'node': node.id}) }}"
                                       class="btn btn-secondary"
                                       aria-label="{{ 'Edit: '|t }}{{ node.label }}">
                                        {{ 'Edit:'|t ~ ' ' ~ node.label }}
                                    </a>
                                </div>
                               {% endif %}

                        </li>

                    {% endif %}
                {% endfor %}
            </ul>
        </section>
    {% endif %}
{% endif %}