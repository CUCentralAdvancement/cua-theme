{#-
  =============================================================================
  COMPONENT: Lead Story Grid / Impact Stories (Multi-Campus)
  VERSION: 4.2.0 | Drupal 11 / PHP 8.4
  STABILITY: Production-Stable | Schema.org + Google Rich Results Validated
-#}

{{ attach_library('cua_theme/call-to-action') }}

{% apply spaceless %}

{# Lead Story classes #}
{%- set lead_story_classes = [
  'block',
  'block-' ~ configuration.provider|clean_class,
  'block-' ~ plugin_id|clean_class,
  'col',
  'lead-story-item',
  id ? 'block--class--lead-story-' ~ id|clean_class : null,
] | merge(utility_classes ?: []) | filter(v => v) | join(' ') -%}

{# Admin controls #}
{% if user.hasPermission('administer site configuration') %}
	<nav class="admin-interface d-flex justify-content-center gap-2 m-2" aria-label="Admin Actions">
		<a href="/lead-story/sort" class="btn btn-sm btn-admin-app">
			{{ 'Sort and manage lead stories'|t }}
		</a>
		<a href="/node/add/gi" class="btn btn-sm btn-admin-app">
			{{ 'Add new lead story'|t }}
		</a>
	</nav>
{% endif %}

{{ title_prefix }}
{{ title_suffix }}

{# Ensure view has results #}
{% if content['#view'].result is not empty %}
	{% set view = content['#view'] %}

	<section class="container-fluid cu-bd-black pt-3 pb-5 px-2" role="region" aria-labelledby="lead-story-section-title" itemscope itemtype="https://schema.org/ItemList">

		<meta itemprop="name" content="Impact Stories from CU Boulder, UCCS, CU Denver, and Anschutz">
		<meta itemprop="itemListOrder" content="https://schema.org/ItemListOrderDescending">
		<meta itemprop="numberOfItems" content="{{ view.result|length }}">

		<h2 id="lead-story-section-title" class="cua-gold text-center mb-4">
			{{ "How Giving Shapes Lives at the University of Colorado"|t }}
		</h2>

		<ul class="row list-unstyled" aria-labelledby="lead-story-section-title">

			{% for row in view.result %}
				{% if row._entity is not empty %}
					{% set node = row._entity %}
					{% set heading_id = 'lead-story-item-' ~ node.id ~ '-title' %}
					{% set body_id = 'lead-story-item-' ~ node.id ~ '-body' %}
					{% set link = node.field_link.uri ?: '#' %}
					{% set description_text = (node.body.summary ?: node.body.value|striptags)|trim %}

					{# Extract author from Drupal user #}
					{% set email = node.getOwner().getEmail() %}
					{% set author_name = email|split('@')[0]|replace({'.':' '})|title %}

					<li class="col-12 col-sm-6 col-lg-3 lead-story-wrapper mb-4" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">

						<meta itemprop="position" content="{{ loop.index }}">

						<div itemprop="item" itemscope itemtype="https://schema.org/Article">

							<meta itemprop="url" content="{{ link }}">
							<meta itemprop="mainEntityOfPage" content="{{ link }}">
							<meta itemprop="datePublished" content="{{ node.created.value|date('c') }}">
							<meta itemprop="dateModified" content="{{ node.changed.value|date('c') }}">
							<meta
							itemprop="description" content="{{ description_text }}">

							{# Publisher #}
							<div itemprop="publisher" itemscope itemtype="https://schema.org/Organization">
								<meta itemprop="name" content="University of Colorado">
								<link itemprop="url" href="https://giving.cu.edu">
							</div>

							{# Author — same 3-step fallback as node.html.twig #}
							{% set _owner = node.getOwner() %}
							{% set _email = _owner.getEmail() %}
							{% set _display_name = _owner.getDisplayName() %}

							{% if ' ' in _display_name and '@' not in _display_name %}
							{% set _author_name = _display_name %}
							{% elseif '@' in _email %}
							{% set _author_name = _email|split('@')[0]|replace({'.': ' ', '_': ' ', '-': ' '})|title %}
							{% else %}
							{% set _author_name = 'CU Advancement Staff' %}
							{% endif %}
							{% set _author_has_name = ' ' in _author_name %}

							{# Author #}
							<div itemprop="author" itemscope itemtype="https://schema.org/{{ _author_has_name ? 'Person' : 'Organization' }}">
								<meta itemprop="name" content="{{ _author_has_name ? _author_name : 'University of Colorado Advancement' }}">
								<link itemprop="url" href="https://www.giving.cu.edu/impact-stories">
							</div>

							<a href="{{ link }}" id="lead-story-item-{{ node.id }}" class="{{ lead_story_classes }} text-decoration-none h-100 d-flex flex-column story-link" rel="bookmark" aria-describedby="{{ body_id }}" data-story-id="{{ node.id }}">

								<article class="m-2 shadow {{ node.field_color_background.value ?: 'cua-black-opacity-75' }} flex-grow-1 d-flex flex-column">

									<div
										class="position-relative">

										{# Optional flag #}
										{% if node.field_flag.value == 'flag_on' %}
											{% set flag_classes = ['flag','py-2',node.field_flag_background.value ?: ''] | filter(v => v) %}
											<div class="position-absolute start-0 top-0 z-index-1">
												<div class="{{ flag_classes|join(' ')|trim }}" style="width:max-content;display:flex;align-items:center;padding:5px 10px;white-space:nowrap;">
													{% if node.field_icon.value %}
														<i class="{{ node.field_icon.value }} {{ node.field_icon_size.value }} px-1" style="color:{{ node.field_icon_color.value }}" aria-hidden="true"></i>
													{% endif %}
													{% if node.field_flag_title.value %}
														<span class="flag-title">
															{{ node.field_flag_title.value|trim }}
														</span>
													{% endif %}
												</div>
											</div>
										{% endif %}

										{# ImageObject with fixed known dimensions #}
										{% if node.field_image.entity %}
											{% set image_url = node.field_image.entity.fileuri | image_style('lead_story') %}
											{% set alt_text = node.field_image.alt|trim ?: 'Story image for ' ~ node.label|trim %}

											<figure class="card-header mb-2" itemprop="image" itemscope itemtype="https://schema.org/ImageObject">

												<img src="{{ image_url }}" alt="{{ alt_text }}" itemprop="url" loading="{{ loop.first ? 'eager' : 'lazy' }}" fetchpriority="{{ loop.first ? 'high' : 'auto' }}" class="img-fluid w-100">

												<meta itemprop="width" content="353">
												<meta itemprop="height" content="235.8">
											</figure>
										{% endif %}
									</div>

									<div class="lead-story-content px-3 pt-2 flex-grow-1 d-flex flex-column">
										<header>
											<h3 id="{{ heading_id }}" class="fs-4 fw-bold" itemprop="headline">
												{{ node.label|trim }}
											</h3>
											<meta itemprop="name" content="{{ node.label|trim }}">
										</header>

										<div id="{{ body_id }}" class="lead-story-body mb-2" itemprop="articleBody">
											{{ node.body.value|raw }}
										</div>
									</div>

									{% if node.field_link.title %}
										<div class="card-footer card-story mb-2">
											<span class="btn outline-btn-cu-bg-black text-decoration-none p-2 mt-3 w-100 text-start" aria-hidden="true">
												{{ node.field_link.title|trim }}
											</span>
										</div>
									{% endif %}

								</article>
							</a>
						</div>
					</li>

				{% endif %}
			{% endfor %}
		</ul>`

		<nav class="d-flex justify-content-center my-4" aria-label="More Stories Navigation">
			<a href="/impact-stories" class="btn btn-primary">
				{{ 'Browse More Stories'|t }}
			</a>
		</nav>

	</section>

{% endif %}

{% endapply %}
