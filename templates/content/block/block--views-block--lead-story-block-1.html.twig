{#-
  =============================================================================
  COMPONENT: Lead Story Grid / Impact Stories (Multi-Campus)
  VERSION: 5.0.0 | Drupal 11 / PHP 8.4
  STABILITY: Production-Stable
  SCHEMA STRATEGY (2026-05):
    - Single JSON-LD <script> block replaces all Microdata attributes
    - ItemList built in a pre-loop before HTML renders — view owns all items
      simultaneously so ItemList is semantically valid here (unlike Layout
      Builder CTA blocks which are isolated)
    - JSON-LD preferred by Google & AI crawlers over Microdata in 2026
    - All itemscope / itemtype / itemprop attributes removed from HTML
  =============================================================================
-#}

{{ attach_library('cua_theme/call-to-action') }}

{% apply spaceless %}

{# Lead Story classes #}
{%- set lead_story_classes = [
  'block',
  'block-' ~ configuration.provider|clean_class,
  'block-' ~ plugin_id|clean_class,
  'col',
  'lead-story-item',
  id ? 'block--class--lead-story-' ~ id|clean_class : null,
] | merge(utility_classes ?: []) | filter(v => v) | join(' ') -%}

{# Admin controls #}
{% if user.hasPermission('administer site configuration') %}
  <nav class="admin-interface d-flex justify-content-center gap-2 m-2" aria-label="Admin Actions">
    <a href="/lead-story/sort" class="btn btn-sm btn-admin-app">
      {{ 'Sort and manage lead stories'|t }}
    </a>
    <a href="/node/add/gi" class="btn btn-sm btn-admin-app">
      {{ 'Add new lead story'|t }}
    </a>
  </nav>
{% endif %}

{{ title_prefix }}
{{ title_suffix }}

{% if content['#view'].result is not empty %}
  {% set view = content['#view'] %}

  {# ===========================================================================
     JSON-LD PRE-LOOP
     Build the full ItemList structure before HTML renders.
     Two passes over view.result is intentional — schema and presentation
     are separate concerns. Drupal entity access is cached; no performance cost.
     =========================================================================== #}
  {%- set _jsonld_items = [] -%}

  {%- for row in view.result -%}
    {%- if row._entity is not empty -%}
      {%- set node = row._entity -%}
      {%- set _link            = node.field_link.uri ?: '#' -%}
      {%- set _description     = (node.body.summary ?: node.body.value|striptags)|trim -%}

      {# Author — 3-step fallback #}
      {%- set _owner        = node.getOwner() -%}
      {%- set _email        = _owner.getEmail() -%}
      {%- set _display_name = _owner.getDisplayName() -%}
      {%- if ' ' in _display_name and '@' not in _display_name -%}
        {%- set _author_name = _display_name -%}
      {%- elseif '@' in _email -%}
        {%- set _author_name = _email|split('@')[0]|replace({'.': ' ', '_': ' ', '-': ' '})|title -%}
      {%- else -%}
        {%- set _author_name = 'CU Advancement Staff' -%}
      {%- endif -%}
      {%- set _author_is_person = ' ' in _author_name -%}

      {# Build Article — image added conditionally to avoid null key in output #}
      {%- set _article = {
        '@type':         'Article',
        'url':           _link,
        'headline':      node.label|trim,
        'description':   _description,
        'datePublished': node.created.value|date('c'),
        'dateModified':  node.changed.value|date('c'),
        'author': {
          '@type': _author_is_person ? 'Person' : 'Organization',
          'name':  _author_is_person ? _author_name : 'University of Colorado Advancement',
          'url':   'https://www.giving.cu.edu/impact-stories'
        },
        'publisher': {
          '@type': 'Organization',
          'name':  'University of Colorado',
          'url':   'https://giving.cu.edu'
        }
      } -%}

      {%- if node.field_image.entity -%}
        {%- set _image_url_raw = node.field_image.entity.fileuri|image_style('lead_story') -%}
        {%- set _image_url = (_image_url_raw starts with 'http') ? _image_url_raw : ('https://www.giving.cu.edu/' ~ _image_url_raw|trim('/')) -%}
        {%- set _image_alt = node.field_image.alt|trim ?: 'Story image for ' ~ node.label|trim -%}
        {%- set _article = _article|merge({
          'image': {
            '@type':   'ImageObject',
            'url':     _image_url,
            'width':   360,
            'height':  240,
            'caption': _image_alt
          }
        }) -%}
      {%- endif -%}

      {%- set _jsonld_items = _jsonld_items|merge([{
        '@type':    'ListItem',
        'position': loop.index,
        'item':     _article
      }]) -%}

    {%- endif -%}
  {%- endfor -%}

  {%- set _jsonld = {
    '@context':       'https://schema.org',
    '@type':          'ItemList',
    'name':           'Impact Stories from CU Boulder, UCCS, CU Denver, and Anschutz',
    'itemListOrder':  'https://schema.org/ItemListOrderDescending',
    'numberOfItems':  view.result|length,
    'itemListElement': _jsonld_items
  } -%}

  <script type="application/ld+json">
  {{ _jsonld|json_encode|raw }}
  </script>

  {# ===========================================================================
     HTML — layout unchanged, Microdata attributes removed
     =========================================================================== #}
  <section
      class="container-fluid cu-bd-black pt-3 pb-5 px-2"
      role="region"
      aria-labelledby="lead-story-section-title">

    <h2 id="lead-story-section-title" class="cua-gold text-center mb-4">
      {{ "How Giving Shapes Lives at the University of Colorado"|t }}
    </h2>

    <ul class="row list-unstyled" aria-labelledby="lead-story-section-title">

      {% for row in view.result %}
        {% if row._entity is not empty %}
          {% set node = row._entity %}
          {% set heading_id = 'lead-story-item-' ~ node.id ~ '-title' %}
          {% set body_id    = 'lead-story-item-' ~ node.id ~ '-body' %}
          {% set link       = node.field_link.uri ?: '#' %}

          <li class="col-12 col-sm-6 col-lg-3 lead-story-wrapper mb-4">

            <a href="{{ link }}"
               id="lead-story-item-{{ node.id }}"
               class="{{ lead_story_classes }} text-decoration-none h-100 d-flex flex-column story-link"
               rel="bookmark"
               aria-describedby="{{ body_id }}"
               data-story-id="{{ node.id }}">

              <article class="m-2 shadow {{ node.field_color_background.value ?: 'cua-black-opacity-75' }} flex-grow-1 d-flex flex-column">

                <div class="position-relative">

                  {# Flag / Badge #}
                  {% if node.field_flag.value == 'flag_on' %}
                    {%- set flag_classes = [
                      'flag',
                      'py-2',
                      node.field_flag_background.value ?: null,
                    ]|filter(v => v) -%}
                    <div class="position-absolute start-0 top-0 z-1">
                      <div class="{{ flag_classes|join(' ')|trim }}"
                           style="width:max-content;display:flex;align-items:center;padding:5px 10px;white-space:nowrap;">
                        {% if node.field_icon.value %}
                          <i class="{{ node.field_icon.value }} {{ node.field_icon_size.value }} px-1"
                             style="color:{{ node.field_icon_color.value }}"
                             aria-hidden="true"></i>
                        {% endif %}
                        {% if node.field_flag_title.value %}
                          <span class="flag-title">{{- node.field_flag_title.value|trim -}}</span>
                        {% endif %}
                      </div>
                    </div>
                  {% endif %}

                  {# Image #}
                  {% if node.field_image.entity %}
                    {%- set image_url = node.field_image.entity.fileuri|image_style('lead_story') -%}
                    {%- set alt_text  = node.field_image.alt|trim ?: 'Story image for ' ~ node.label|trim -%}
                    <figure class="card-header mb-2">
                      <img
                        src="{{ image_url }}"
                        alt="{{ node.field_image.alt|default(label)|trim }}"
                        width="360"
                        height="240"
                        loading="{{ loop.first ? 'eager' : 'lazy' }}"
                        fetchpriority="{{ loop.first ? 'high' : 'auto' }}"
                        class="card-header mb-2"/>
                    </figure>
                  {% endif %}

                </div>{#- /.position-relative -#}

                <div class="lead-story-content px-3 pt-2 flex-grow-1 d-flex flex-column">
                  <header>
                    <h3 id="{{ heading_id }}" class="fs-4 fw-bold">
                      {{- node.label|trim -}}
                    </h3>
                  </header>

                  <div id="{{ body_id }}" class="lead-story-body mb-2">
                    {{ node.body.value|raw }}
                  </div>
                </div>

                {% if node.field_link.title %}
                  <div class="card-footer card-story mb-2">
                    <span class="btn outline-btn-cu-bg-black text-decoration-none p-2 mt-3 w-100 text-start"
                          aria-hidden="true">
                      {{- node.field_link.title|trim -}}
                    </span>
                  </div>
                {% endif %}

              </article>
            </a>

          </li>

        {% endif %}
      {% endfor %}

    </ul>

    <nav class="d-flex justify-content-center my-4" aria-label="More Stories Navigation">
      <a href="/impact-stories" class="btn btn-primary">
        {{ 'Browse More Stories'|t }}
      </a>
    </nav>

  </section>

{% endif %}

{% endapply %}