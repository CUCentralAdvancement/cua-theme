{#
================================================================================
  node--article.html.twig

  SCHEMA: JSON-LD only. This template is the single source of truth for this
  node's structured data.

  IMPORTANT — if a validator reports "Format: Microdata" errors for this page
  (e.g. contentUrl/image/itemprop issues), those are NOT coming from this file.
  A field template or the base theme is emitting itemscope/itemtype/itemprop
  attributes (Microdata) in addition to this JSON-LD. View-source and search
  for `itemtype` to find it, then strip the microdata attributes from that
  field template. Two schema formats for one entity is the root cause.

  AUTHOR: Institutional voice — author is the Organization, never a named
  Person. We do NOT derive author identity from CMS accounts (no usernames,
  no email-derived names, no individual fallback).
================================================================================
#}

{{ attach_library('bootstrap_barrio/node') }}

{#-- VARIABLES ----------------------------------------------------------------#}

{%- set _org_name = 'University of Colorado Foundation' -%}
{%- set _org_url  = 'https://www.giving.cu.edu' -%}
{%- set _logo_url = 'https://www.giving.cu.edu/themes/contrib/cua_theme/images/logo.svg' -%}

{# IMAGE — always resolve to an absolute URL; fall back to the site logo #}
{%- set _image_url = _logo_url -%}
{%- if node.field_image is defined and node.field_image.entity is not empty -%}
  {%- set _image_url = file_url(node.field_image.entity.fileuri) -%}
  {%- if _image_url starts with '/' -%}
    {%- set _image_url = _org_url ~ _image_url -%}
  {%- endif -%}
{%- endif -%}

{# DESCRIPTION — summary preferred, then trimmed body, then the title #}
{%- set _description = node.label|render|striptags|trim -%}
{%- if node.body.summary is defined and node.body.summary|render|striptags|trim -%}
  {%- set _description = node.body.summary|render|striptags|trim -%}
{%- elseif node.body.value is defined and node.body.value|render|striptags|trim -%}
  {# core-safe slice (truncate filter requires Twig Extensions, not always present) #}
  {%- set _description = node.body.value|render|striptags|trim|slice(0, 300) -%}
{%- endif -%}

{# SCHEMA TYPE — only article and lead_story are Article; everything else WebPage #}
{%- set _schema_type = 'WebPage' -%}
{%- if node.bundle in ['article', 'lead_story'] -%}
  {%- set _schema_type = 'Article' -%}
{%- endif -%}

{# CANONICAL URL — absolute #}
{%- set _canonical = url('<current>', {}, {'absolute': true})|render -%}

{# CLASSES #}
{%- set _classes = [
  'node',
  'node--type-' ~ node.bundle|clean_class,
  view_mode ? 'node--view-mode-' ~ view_mode|clean_class
] -%}

{#-- JSON-LD ------------------------------------------------------------------#}

{% if view_mode == 'full' %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": {{ _schema_type|json_encode|raw }},
  "headline": {{ node.label|render|striptags|trim|json_encode|raw }},
  "description": {{ _description|json_encode|raw }},
  "url": {{ _canonical|json_encode|raw }},
  "datePublished": {{ node.created.value|date('c')|json_encode|raw }},
  "dateModified": {{ node.changed.value|date('c')|json_encode|raw }},
  "image": {
    "@type": "ImageObject",
    "url": {{ _image_url|json_encode|raw }},
    "contentUrl": {{ _image_url|json_encode|raw }}
  },
  "author": {
    "@type": "Organization",
    "name": {{ _org_name|json_encode|raw }},
    "url": {{ _org_url|json_encode|raw }}
  },
  "publisher": {
    "@type": "Organization",
    "name": {{ _org_name|json_encode|raw }},
    "url": {{ _org_url|json_encode|raw }},
    "logo": {
      "@type": "ImageObject",
      "url": {{ _logo_url|json_encode|raw }}
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": {{ _canonical|json_encode|raw }}
  }
}
</script>
{% endif %}

{#-- HTML ---------------------------------------------------------------------#}

<article{{ attributes.addClass(_classes) }}>
  <header>
    {{ title_prefix }}
    {% if not page %}
      {# In listing/teaser context the core `label` variable comes through
         empty in this render path, so build a linked title from the node
         itself — a listing title should link to the article anyway. #}
      {%- set _node_url = url('entity.node.canonical', {'node': node.id})|render -%}
      <h2 class="mt-0">
        <a href="{{ _node_url }}" class="text-decoration-none">{{ node.label }}</a>
      </h2>
    {% endif %}
    {{ title_suffix }}
  </header>

  <div class="node__content">
    {{ content }}
  </div>
</article>