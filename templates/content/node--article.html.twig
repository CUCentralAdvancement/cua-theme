{#
================================================================================
  node.html.twig — FINAL (JSON-LD ONLY + AUTHOR FALLBACK)
================================================================================
#}

{{ attach_library('bootstrap_barrio/node') }}

{#-- VARIABLES ----------------------------------------------------------------#}

{%- set _owner        = node.getOwner() -%}
{%- set _email        = _owner.getEmail() -%}
{%- set _display_name = _owner.getDisplayName() -%}

{# PRIMARY AUTHOR NAME #}
{%- if ' ' in _display_name and '@' not in _display_name -%}
  {%- set _author_name = _display_name -%}
{%- elseif '@' in _email -%}
  {%- set _author_name = _email|split('@')[0]|replace({'.': ' ', '_': ' ', '-': ' '})|title -%}
{%- else -%}
  {%- set _author_name = '' -%}
{%- endif -%}

{%- set _author_has_name = ' ' in _author_name -%}

{# FALLBACK AUTHOR #}
{%- set _fallback_name = 'Christine Deorio' -%}
{%- set _fallback_slug = 'christine-deorio' -%}
{%- set _fallback_url  = 'https://www.giving.cu.edu/about-us/staff/christine-deorio' -%}

{# AUTHOR SLUG + URL #}
{%- if _author_has_name -%}
  {%- set _author_slug = _author_name
    |lower
    |replace({'.':' ','_':' ','-':' '})
    |split(' ')
    |filter(v => v)
    |join('-')
  -%}
  {%- set _author_url = 'https://www.giving.cu.edu/about-us/staff/' ~ _author_slug -%}
{%- else -%}
  {%- set _author_name = _fallback_name -%}
  {%- set _author_url  = _fallback_url -%}
{%- endif -%}

{# LOGO #}
{%- set _logo_url = 'https://www.giving.cu.edu/themes/contrib/cua_theme/images/logo.svg' -%}

{# IMAGE #}
{%- set _image_url = _logo_url -%}
{%- if node.field_image is defined and node.field_image.entity is not empty -%}
  {%- set _image_url = file_url(node.field_image.entity.fileuri) -%}
  {%- if _image_url starts with '/' -%}
    {%- set _image_url = 'https://www.giving.cu.edu' ~ _image_url -%}
  {%- endif -%}
{%- endif -%}

{# DESCRIPTION #}
{%- set _description = node.label|render|striptags|trim -%}
{%- if node.body.summary is defined and node.body.summary|render|striptags|trim -%}
  {%- set _description = node.body.summary|render|striptags|trim -%}
{%- elseif node.body.value is defined and node.body.value|render|striptags|trim -%}
  {%- set _description = node.body.value|render|striptags|truncate(300)|trim -%}
{%- endif -%}

{# SCHEMA TYPE #}
{%- set _schema_type = 'Article' -%}
{%- if node.bundle in ['page','landing_page','basic_page','webform','guide'] -%}
  {%- set _schema_type = 'WebPage' -%}
{%- endif -%}

{# CLASSES #}
{%- set _classes = [
  'node',
  'node--type-' ~ node.bundle|clean_class,
  view_mode ? 'node--view-mode-' ~ view_mode|clean_class
] -%}

{#-- JSON-LD ------------------------------------------------------------------#}

{% if view_mode == 'full' %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": {{ _schema_type|json_encode|raw }},
  "headline": {{ node.label|render|striptags|trim|json_encode|raw }},
  "description": {{ _description|json_encode|raw }},
  "url": {{ url('<current>')|render|json_encode|raw }},
  "datePublished": {{ node.created.value|date('c')|json_encode|raw }},
  "dateModified": {{ node.changed.value|date('c')|json_encode|raw }},
  "image": {
    "@type": "ImageObject",
    "url": {{ _image_url|json_encode|raw }}
  },
  "author": {
    "@type": "Person",
    "name": {{ _author_name|json_encode|raw }},
    "url": {{ _author_url|json_encode|raw }}
  },
  "publisher": {
    "@type": "Organization",
    "name": "University of Colorado Advancement",
    "url": "https://www.giving.cu.edu",
    "logo": {
      "@type": "ImageObject",
      "url": {{ _logo_url|json_encode|raw }}
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": {{ url('<current>')|render|json_encode|raw }}
  }
}
</script>
{% endif %}

{#-- HTML ---------------------------------------------------------------------#}

<article{{ attributes.addClass(_classes) }}>
  <header>
    {{ title_prefix }}
    {% if not page %}
      <h2>{{ label }}</h2>
    {% endif %}
    {{ title_suffix }}
  </header>

  <div class="node__content">
    {{ content }}
  </div>
</article>