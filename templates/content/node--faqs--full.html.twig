{# 
FAQ Node Template
Optimized for SEO, accessibility, and AI parsing.
- Adds semantic landmarks
- Improves heading hierarchy
- Adds aria-labels for navigation
- Removes hardcoded absolute URLs where possible
#}

<article{{ attributes.addClass('faq-container') }}>

  <div class="container">
    <div class="row">

      {# -------------------------
         LEFT SIDEBAR (Navigation)
         ------------------------- #}
      <aside class="col-12 col-md-3 mb-4" aria-label="FAQ categories">
        <nav class="p-3">
          <h2 class="h5">FAQ Categories</h2>

          <ul class="nav flex-column">
            <li class="nav-item">
              <a href="/faq" class="nav-link py-1">{{ 'FAQs'|t }}</a>
            </li>
            <li class="nav-item">
              <a href="/faq#general-questions" class="nav-link py-1">{{ 'General questions'|t }}</a>
            </li>
            <li class="nav-item">
              <a href="/faq#ways-to-give" class="nav-link py-1">{{ 'Ways to give'|t }}</a>
            </li>
            <li class="nav-item">
              <a href="/faq#cu-foundation" class="nav-link py-1">{{ 'CU Foundation'|t }}</a>
            </li>
            <li class="nav-item">
              <a href="/faq#common-giving-terms" class="nav-link py-1">{{ 'Common giving terms'|t }}</a>
            </li>
            <li class="nav-item">
              <a href="https://giveto.cu.edu/funds/?a=8403519" class="nav-link py-1">{{ 'Search Funds'|t }}</a>
            </li>
          </ul>
        </nav>
      </aside>

      {# -------------------------
         MAIN CONTENT
         ------------------------- #}
      <main class="col-12 col-md-9 mb-4">

        <header class="title-wrapper mb-4">
          {{ title_prefix }}

          {% if not node.field_show_title.value %}
            <h1 class="visually-hidden">{{ label }}</h1>
          {% else %}
            <h1 class="page-title">{{ label }}</h1>
          {% endif %}

          {{ title_suffix }}
        </header>

        <section{{ content_attributes.addClass('node-content') }}>
          {{ content|without('field_hero', 'field_subtitle') }}
        </section>

      </main>

    </div>
  </div>

</article>
`