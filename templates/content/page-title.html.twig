{#
/**
 * @file
 * Theme override for page titles with visibility control.
 * This prevents the "double title" issue by strictly honoring the 
 * title_visibility variable from the Site Builder.
 */
#}

{{ title_prefix }}

{% if title_visibility|lower == 'visible' %}
    <h1{{ title_attributes.addClass('page-title', 'pt-2') }} id="page-title">
        {{ title }}
    </h1>
{% elseif title_visibility|lower == 'hidden' %}
    <h1{{ title_attributes.addClass('visually-hidden') }} id="page-title">
        {{ title }}
    </h1>
{% endif %}

{{ title_suffix }}