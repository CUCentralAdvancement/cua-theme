{#
  File: views-view-fields--contact--page-3.html.twig
  View: contact | Display: page_3 (CU Foundation Staff Directory)
  Clean HTML only — schema handled entirely by JSON-LD in outer view template.
  No microdata. JSON-LD only per GEO audit recommendation.
#}
{%- apply spaceless -%}

  <div class="contact contact-card">

    {%- if fields.title.content -%}
      <h4 class="cu-line-sm fw-bolder">
        {{- fields.title.content|striptags|trim|raw -}}
      </h4>
    {%- endif -%}

    {%- set position_clean = fields.field_position.content|striptags|trim -%}
    {%- if position_clean -%}
      <div class="contact-position py-2">{{- position_clean|raw -}}</div>
    {%- endif -%}

    {%- set phone_raw = fields.field_office_phone.content|striptags|trim -%}
    {%- if phone_raw -%}
      {%- set phone_clean = phone_raw|replace({'(': '', ')': '', ' ': '-'})|replace({'--': '-'}) -%}
      <div class="contact-phone">
        <a href="tel:{{ phone_clean }}" class="text-decoration-none">
          <i class="fa-solid fa-phone"></i>
          <span class="ms-2">{{- phone_raw -}}</span>
        </a>
      </div>
    {%- endif -%}

    {%- set email_clean = fields.field_email.content|striptags|trim -%}
    {%- if email_clean -%}
      <div class="contact-email mb-2">
        <a href="mailto:{{ email_clean }}" class="text-decoration-none">
          <i class="fa-solid fa-envelope"></i>
          <span class="ms-2">{{- email_clean -}}</span>
        </a>
      </div>
    {%- endif -%}

    {%- set bio_clean = fields.body.content|striptags|trim -%}
    {%- if bio_clean -%}
      <div class="contact-bio">{{- fields.body.content|raw -}}</div>
    {%- endif -%}

    {%- set edit_clean = fields.edit_node.content|striptags|trim -%}
    {%- if edit_clean -%}
      <div class="pt-3">{{- fields.edit_node.content|raw -}}</div>
    {%- endif -%}

  </div>

{%- endapply -%}