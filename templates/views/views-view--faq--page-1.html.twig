{# SCHEMA TEMPLATE #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "name": "Frequently Asked Questions about Giving to the University of Colorado System — CU Boulder, CU Anschutz, CU Denver, and UCCS",
  "mainEntity": [
    {%- for row in view.result -%}
      {%- if row._entity is not empty -%}
        {%- set _q = row._entity.label|striptags|trim -%}
        {%- set _q = _q ends with '?' ? _q : _q ~ '?' -%}
        {%- set _a = row._entity.field_answer.value|render|striptags|replace({'\n': ' ', '&nbsp;': ' '})|trim -%}
    {
      "@type": "Question",
      "name": {{ _q|json_encode|raw }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ _a|json_encode|raw }}
      }
    }{% if not loop.last %},{% endif %}
      {%- endif -%}
    {%- endfor %}
  ]
}
</script>

<div class="faqs view-faq">
  {{ rows }}
</div>