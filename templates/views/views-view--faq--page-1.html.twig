{# SCHEMA TEMPLATE #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "name": "Frequently Asked Questions about Giving to the University of Colorado",
  "mainEntity": [
{% for row in view.result %}
  {% set q = row._entity.label|striptags|trim %}
  {% set a = row._entity.field_answer.value|render|striptags|replace({'\n':' '})|trim %}
  {
    "@type": "Question",
    "name": {{ q|json_encode|raw }},
    "acceptedAnswer": {
      "@type": "Answer",
      "text": {{ a|json_encode|raw }}
    }
  }{% if not loop.last %},{% endif %}
{% endfor %}
  ]
}
</script>

<div class="faqs view-faq">
  {{ rows }}
</div>

{# ONE global script, runs once #}
<script>
document.addEventListener("DOMContentLoaded", function () {
  document.querySelectorAll('.accordion-collapse').forEach(function(el) {
    el.classList.remove('show');
    el.classList.add('collapse');
  });
});
</script>