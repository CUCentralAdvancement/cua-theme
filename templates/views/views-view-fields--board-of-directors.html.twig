{# 
  File: views-view-fields--board-of-directors.html.twig
  Clean HTML only — schema handled entirely by JSON-LD in attachment_2.
  No microdata. Google recommends JSON-LD exclusively.
#}
{%- apply spaceless -%}

  {%- set is_page = (view.current_display == 'page_1') -%}
  {%- set h_tag = is_page ? 'h3' : 'h4' -%}

  {%- set company_raw = fields.field_company.content|striptags|trim -%}
  {%- set retire_keywords = ['retired', 'self-employed', 'self employed', 'freelance', 'consultant', 'independent', 'volunteer', 'former'] -%}
  {%- set is_description = false -%}
  {%- for keyword in retire_keywords -%}
    {%- if company_raw|lower starts with keyword or keyword in company_raw|lower -%}
      {%- set is_description = true -%}
    {%- endif -%}
  {%- endfor -%}

  <div class="contact-card">

    {%- if fields.title.content -%}
      <{{ h_tag }} class="cu-line-sm fw-bolder">
        {{- fields.title.content|striptags|trim|raw -}}
      </{{ h_tag }}>
    {%- endif -%}

    {%- set board_clean = fields.field_board_of_directors.content|striptags|trim -%}
    {%- if board_clean -%}
      <div class="fst-italic bold cu-gold pb-2">{{- board_clean|raw -}}</div>
    {%- endif -%}

    {%- set position_clean = fields.field_position.content|striptags|trim -%}
    {%- if position_clean -%}
      <div class="fst-italic pb-2">{{- position_clean|raw -}}</div>
    {%- endif -%}

    {%- if company_raw -%}
      <div class="fst-italic pb-2">{{- company_raw|raw -}}</div>
    {%- endif -%}

    {%- set home_clean = fields.field_home.content|striptags|trim -%}
    {%- if home_clean -%}
      <div class="pb-2">{{- home_clean|raw -}}</div>
    {%- endif -%}

    {%- set edit_clean = fields.edit_node.content|striptags|trim -%}
    {%- if edit_clean -%}
      <div class="pt-3">{{- fields.edit_node.content|raw -}}</div>
    {%- endif -%}

  </div>

{%- endapply -%}