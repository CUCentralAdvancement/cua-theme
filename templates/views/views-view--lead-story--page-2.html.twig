{#
  File: views-view--lead-story--page-2.html.twig
  View: lead_story | Display: page_2 (Impact Stories)

  Outer wrapper. Renders the normal view output, then emits ONE page-level
  CollectionPage + ItemList JSON-LD block describing the curated story links
  on this page — both internal giving.cu.edu nodes and external news URLs.

  Why a list and not per-card Article: these are references to stories, most
  of which live on other domains. A ListItem carries only url + name, so it
  never misattributes an external story's authorship/publisher to CU. The
  old per-card Article microdata (which claimed CU as publisher and an
  internal editor as author) was removed from
  views-view-fields--lead-story--page-2.html.twig in favour of this.

  Link precedence mirrors the fields template: external field_link wins,
  otherwise the story is the node itself (canonical URL).
#}
{%
  set classes = [
    'view',
    'view-' ~ id|clean_class,
    'view-id-' ~ id,
    'view-display-id-' ~ display_id,
    dom_id ? 'js-view-dom-id-' ~ dom_id,
  ]
%}
<div{{ attributes.addClass(classes) }}>
  {{ title_prefix }}
  {% if title %}
    {{ title }}
  {% endif %}
  {{ title_suffix }}
  {% if header %}
    <div class="view-header">
      {{ header }}
    </div>
  {% endif %}
  {% if exposed %}
    <div class="view-filters">
      {{ exposed }}
    </div>
  {% endif %}
  {% if attachment_before %}
    <div class="attachment attachment-before">
      {{ attachment_before }}
    </div>
  {% endif %}

  {% if rows %}
    <div class="view-content row">
      {{ rows }}
    </div>
  {% elseif empty %}
    <div class="view-empty">
      {{ empty }}
    </div>
  {% endif %}

  {% if pager %}
    {{ pager }}
  {% endif %}
  {% if attachment_after %}
    <div class="attachment attachment-after">
      {{ attachment_after }}
    </div>
  {% endif %}
  {% if more %}
    {{ more }}
  {% endif %}
  {% if footer %}
    <div class="view-footer">
      {{ footer }}
    </div>
  {% endif %}
  {% if feed_icons %}
    <div class="feed-icons">
      {{ feed_icons }}
    </div>
  {% endif %}

  {# Structured data: CollectionPage + ItemList, built in
     cua_theme_preprocess_views_view(). See that hook for the rationale. #}
  {{ impact_stories_jsonld }}
</div>
