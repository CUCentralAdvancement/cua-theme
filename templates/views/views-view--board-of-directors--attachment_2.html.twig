{#
  File: views-view--board-of-directors--attachment_2.html.twig
  Outputs JSON-LD for all board members — fires as attachment to page_1.
  field_board_of_directors is a taxonomy reference — must use entity.label not .value.
#}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "University of Colorado Foundation",
  "subOrganization": {
    "@type": "Organization",
    "name": "Board of Directors"
  },
  "member": [
    {% for row in view.result %}
      {%- set name      = (row._entity.label ~ '')|replace({'&nbsp;': ' '})|striptags|trim -%}
      {%- set jobtitle  = (row._entity.field_position[0].value ~ '')|striptags|trim -%}
      {%- set rolelabel = (row._entity.field_board_of_directors[0].entity.label ~ '')|striptags|trim -%}
      {%- set company   = (row._entity.field_company[0].value ~ '')|striptags|trim -%}
      {%- set co = company|lower -%}
      {%- set is_retired = (
        'retired'       in co or
        'self-employed' in co or
        'self employed' in co or
        'freelance'     in co or
        'consultant'    in co or
        'independent'   in co or
        'volunteer'     in co or
        'former'        in co
      ) -%}
    {
      "@type": "OrganizationRole",
      "roleName": {{ rolelabel|json_encode|raw }},
      "member": {
        "@type": "Person",
        "name": {{ name|json_encode|raw }}
        {%- if jobtitle -%},
        "jobTitle": {{ jobtitle|json_encode|raw }}
        {%- endif -%}
        {%- if company and not is_retired -%},
        "worksFor": {
          "@type": "Organization",
          "name": {{ company|json_encode|raw }}
        }
        {%- endif -%}
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>

{%- set total_result     = drupal_view_result('board_of_directors', 'attachment_4') -%}
{%- set elected_result   = drupal_view_result('board_of_directors', 'attachment_5') -%}
{%- set exofficio_result = drupal_view_result('board_of_directors', 'attachment_6') -%}

{%- set total     = total_result[0].nid is defined ? (total_result[0].nid ~ '') : 0 -%}
{%- set elected   = elected_result[0].nid is defined ? (elected_result[0].nid ~ '') : 0 -%}
{%- set exofficio = exofficio_result[0].nid is defined ? (exofficio_result[0].nid ~ '') : 0 -%}

<div class="view-header">
  <h3 class="cu-line mt-5">{{ 'Board of Directors'|t }}</h3>
  <div class="board-counts fw-bold mb-3">
    {{ 'Current total of'|t }} {{ total }}: {{ elected }} {{ 'Elected,'|t }} {{ exofficio }} {{ 'Ex-Officio'|t }}
  </div>
</div>

{%- if rows -%}
  <div class="view-content">
    <div class="row g-0">
      {{- rows -}}
    </div>
  </div>
{%- endif -%}