{#
  This header dynamically calculates:
    - total board members
    - elected members
    - ex‑officio members

  It pulls counts from three separate View displays:
    board_of_directors / current_total
    board_of_directors / elected
    board_of_directors / ex_officio

  drupal_view_result() returns ONLY the rows (no markup),
  so |length gives accurate counts without recursion.

  This entire block is self‑maintaining — no manual updates needed.
#}

{% set total = drupal_view_result('board_of_directors', 'current_total')|length %}
{% set elected = drupal_view_result('board_of_directors', 'elected')|length %}
{% set exofficio = drupal_view_result('board_of_directors', 'ex_officio')|length %}

<div class="view-header" itemscope itemtype="https://schema.org/Organization">
  <h3 class="cu-line mt-5" itemprop="name">{{ 'Board of Directors'|t }}</h3>

  <div class="board-counts fw-bold mb-3">
    <span itemprop="description">
      {{ 'Current total of'|t }} {{ total }}{{ ':'|t }}
      {{ elected }} {{ 'Elected'|t }}{{ ','|t }}
      {{ exofficio }} {{ 'Ex‑Officio'|t }}
    </span>
  </div>

  <meta itemprop="parentOrganization" content="University of Colorado Foundation">
</div>

{% if rows %}
  <div class="view-content">
    <div class="row g-0">
      {{ rows }}
    </div>
  </div>
{% endif %}
