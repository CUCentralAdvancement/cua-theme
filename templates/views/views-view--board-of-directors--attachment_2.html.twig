{#
  This header dynamically calculates:
    - total board members
    - elected members
    - ex-officio members
  Each attachment view returns a single aggregated COUNT row,
  so we read the nid field value from the first row directly.
  This entire block is self-maintaining — no manual updates needed.
#}
{% set total     = drupal_view_result('board_of_directors', 'attachment_4')[0].nid ?? 0 %}
{% set elected   = drupal_view_result('board_of_directors', 'attachment_5')[0].nid ?? 0 %}
{% set exofficio = drupal_view_result('board_of_directors', 'attachment_6')[0].nid ?? 0 %}

<div class="view-header" itemscope itemtype="https://schema.org/Organization">
  <h3 class="cu-line mt-5" itemprop="name">{{ 'Board of Directors'|t }}</h3>
  <div class="board-counts fw-bold mb-3">
    <span itemprop="description">
      {{ 'Current total of'|t}} {{ total }}: {{ elected }} {{ 'Elected,'|t}} {{ exofficio }} {{ 'Ex-Officio'|t}}
    </span>
  </div>
  <meta itemprop="parentOrganization" content="University of Colorado Foundation">
</div>

{% if rows %}
  <div class="view-content">
    <div class="row g-0">
      {{ rows }}
    </div>
  </div>
{% endif %}