{#
  File: views-view--financials--block-1.html.twig
  View: financials | Display: block_1 (Policies and Statements)
  JSON-LD: DigitalDocument list for policy and compliance documents.
  Self-maintaining — add/remove documents in Drupal, schema updates automatically.
#}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "CU Foundation Policies and Statements",
  "description": "Financial policies, IRS filings, audited statements, and investment policy documents for the University of Colorado Foundation",
  "itemListElement": [
    {% set is_first = true %}
    {% set list_position = 1 %}
    {% for row in view.result %}
      {%- set has_protected = row._entity.field_protected_file[0] is not empty -%}
      {%- set has_file      = row._entity.field_file[0] is not empty -%}
      {%- if has_protected or has_file -%}

        {%- if has_protected -%}
          {%- set doc_title = (row._entity.field_protected_file[0].description ~ '')|striptags|trim -%}
          {%- if not doc_title -%}
            {%- set doc_title = (row._entity.label ~ '')|striptags|trim -%}
          {%- endif -%}
          {%- set doc_url = file_url(row._entity.field_protected_file[0].entity.uri.value) -%}
        {%- else -%}
          {%- set doc_title = (row._entity.field_file[0].description ~ '')|striptags|trim -%}
          {%- if not doc_title -%}
            {%- set doc_title = (row._entity.label ~ '')|striptags|trim -%}
          {%- endif -%}
          {%- set doc_url = file_url(row._entity.field_file[0].entity.uri.value) -%}
        {%- endif -%}

        {%- if not is_first -%},{%- endif -%}
    {
      "@type": "ListItem",
      "position": {{ list_position }},
      "item": {
        "@type": "DigitalDocument",
        "name": {{ doc_title|json_encode|raw }},
        "url": {{ doc_url|json_encode|raw }},
        "encodingFormat": "application/pdf",
        "publisher": {
          "@type": "Organization",
          "name": "University of Colorado Foundation",
          "url": "https://cufund.org"
        }
      }
    }
        {%- set is_first = false -%}
        {%- set list_position = list_position + 1 -%}
      {%- endif -%}
    {% endfor %}
  ]
}
</script>

{%- if header -%}
  <div class="view-header">{{- header -}}</div>
{%- endif -%}

{%- if rows -%}
  <div class="view-content row">
    {{- rows -}}
  </div>
{%- elseif empty -%}
  <div class="view-empty">{{- empty -}}</div>
{%- endif -%}

{%- if pager -%}
  {{- pager -}}
{%- endif -%}